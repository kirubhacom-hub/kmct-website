---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT School of Business</title>
    <meta name="description" content="Your Management Career Begins at KMCT School of Business. MBA & MCA Admissions 2026." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">
    
    <Header />

    <!-- HERO SECTION -->
    <section class="relative overflow-hidden" style="padding-top: 120px; background-image: linear-gradient(rgba(255,255,255,0.85), rgba(255,255,255,0.85)), url('https://images.unsplash.com/photo-1542744173-8e7e53415bb0?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-position: center top; background-color: white;">
      
      <!-- Centered hero content -->
      <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 flex-1 lg:pb-16 max-w-5xl mx-auto animate-fade-up">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-rose-50/90 text-[#8A1538] border border-[#8A1538]/20 font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          KTU Affiliated &middot; AICTE Approved
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-4 max-w-5xl drop-shadow-sm">
          KMCT School of <span class="text-[#8A1538]">Business</span>
        </h1>
        
        <p class="text-xl sm:text-2xl font-serif text-[#8A1538] italic mb-8 drop-shadow-sm">Your Management Career Begins Here</p>
        
        <p class="text-lg sm:text-xl text-gray-600 max-w-4xl leading-relaxed font-medium mb-12">
          KMCT School of Business has been running full-time postgraduate programmes since 2004. Two degrees and both KTU affiliated & AICTE approved. The placement cell understands what companies are looking for, maintaining relationships with recruiters across logistics, healthcare, technology, and retail.
        </p>



        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#8A1538] text-white rounded-full font-bold text-sm lg:text-base hover:bg-[#6b0f2a] transition-all duration-300 shadow-[0_0_20px_rgba(138,21,56,0.3)] hover:-translate-y-1">
            APPLY FOR MBA & MCA 2026 BATCH
          </a>
          <a href="#programs" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-[#0a2542] border-2 border-[#0a2542]/10 rounded-full font-bold text-sm lg:text-base hover:border-[#0a2542]/30 hover:bg-gray-50 transition-all duration-300">
            CHECK YOUR ELIGIBILITY
          </a>
        </div>
      </div>

      <!-- Infinite auto-scroll image marquee -->
      <div class="relative z-10 overflow-hidden pb-0" style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);">
        <div class="marquee-track flex gap-4 w-max">
          <!-- Set 1 -->
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32b7?auto=format&fit=crop&q=80&w=600&h=400" alt="Business Strategy" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1521737711867-e3cb130dd22a?auto=format&fit=crop&q=80&w=600&h=400" alt="Students Meeting" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80&w=600&h=400" alt="Presentation" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1542744094-24638ea0b3b5?auto=format&fit=crop&q=80&w=600&h=400" alt="Networking" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1507679799987-c73779587ccf?auto=format&fit=crop&q=80&w=600&h=400" alt="Executive" class="w-full h-full object-cover" />
          </div>
          <!-- Set 2 -->
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32b7?auto=format&fit=crop&q=80&w=600&h=400" alt="Business Strategy" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1521737711867-e3cb130dd22a?auto=format&fit=crop&q=80&w=600&h=400" alt="Students Meeting" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80&w=600&h=400" alt="Presentation" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1542744094-24638ea0b3b5?auto=format&fit=crop&q=80&w=600&h=400" alt="Networking" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1507679799987-c73779587ccf?auto=format&fit=crop&q=80&w=600&h=400" alt="Executive" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- STATS SECTION -->
    <section class="w-full bg-kmct-navy py-16 relative z-10 overflow-hidden shadow-2xl">
      <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-[#8A1538] via-rose-400 to-[#8A1538]"></div>
      <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #ffffff 0%, transparent 70%);"></div>
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-20">
        <div class="flex items-center justify-center gap-4 sm:gap-8 mb-12">
          <div class="h-[1px] bg-gradient-to-r from-transparent to-rose-500 w-16 sm:w-32 opacity-50"></div>
          <p class="text-center text-xs sm:text-sm font-bold uppercase tracking-[0.3em] text-rose-300 m-0">KMCT School of Business — By The Numbers</p>
          <div class="h-[1px] bg-gradient-to-l from-transparent to-rose-500 w-16 sm:w-32 opacity-50"></div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-4 lg:gap-x-0 items-center lg:divide-x lg:divide-white/10">
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 0ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="900" data-suffix="+">900+</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">MBA<br/>Alumni</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 150ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="350" data-suffix="+">350+</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">MCA<br/>Alumni</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 300ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="74" data-suffix="%">74%</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Placement<br/>Rate</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 450ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="20" data-suffix="+">20+</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Years<br/>Running</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PG PROGRAMS SECTION -->
    <section class="py-24 relative border-y border-gray-200" id="programs" style="background-image: linear-gradient(rgba(249, 250, 251, 0.95), rgba(249, 250, 251, 0.95)), url('https://images.unsplash.com/photo-1556761175-5973dc0f32b7?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-attachment: fixed; background-position: center;">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <div class="text-center mb-16">
          <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Choose your path. Own your future.</h2>
          <p class="text-lg text-gray-600 font-medium max-w-2xl mx-auto">
            Our specialized MBA and MCA degree programs are tailored to produce industry-ready graduates.
          </p>
        </div>

        <!-- PROGRAM CARDS -->
        <div class="grid lg:grid-cols-2 gap-8 mb-16">
          
          <!-- MBA Card -->
          <div class="bg-white rounded-3xl p-10 border border-gray-100 shadow-xl hover:-translate-y-2 transition-transform duration-300 flex flex-col h-full group">
            <div class="w-16 h-16 bg-rose-50 text-[#8A1538] rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <p class="text-[#8A1538] font-bold text-xs tracking-widest uppercase mb-3">Master of Business Administration</p>
            <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-6 leading-tight">MBA Program</h3>
            
            <ul class="space-y-4 text-gray-600 font-medium mb-10 flex-1">
              <li class="flex items-start gap-3"><span class="text-[#8A1538] font-bold uppercase w-32 tracking-wider text-xs pt-1">Duration</span><span>2 Years</span></li>
              <li class="flex items-start gap-3"><span class="text-[#8A1538] font-bold uppercase w-32 tracking-wider text-xs pt-1">Seats</span><span>60 Seats</span></li>
              <li class="flex items-start gap-3"><span class="text-[#8A1538] font-bold uppercase w-32 tracking-wider text-xs pt-1">Eligibility</span><span>Any Graduate</span></li>
              <li class="flex items-start gap-3"><span class="text-[#8A1538] font-bold uppercase w-32 tracking-wider text-xs pt-1">Entrance</span><span>KMAT / CMAT / CAT</span></li>
              <li class="flex items-start gap-3"><span class="text-[#8A1538] font-bold uppercase w-32 tracking-wider text-xs pt-1">University</span><span>KTU</span></li>
              <li class="flex items-start gap-3"><span class="text-[#8A1538] font-bold uppercase w-32 tracking-wider text-xs pt-1">Specializations</span><span>Marketing, Finance, HR, Operations, Systems — or pick two.</span></li>
            </ul>
            
            <a href="#admissions" class="block text-center px-8 py-4 bg-[#8A1538] text-white rounded-xl font-bold hover:bg-[#6b0f2a] transition-all shadow-md hover:shadow-lg">APPLY FOR MBA</a>
          </div>

          <!-- MCA Card -->
          <div class="bg-kmct-navy text-white rounded-3xl p-10 border border-white/10 shadow-xl hover:-translate-y-2 transition-transform duration-300 flex flex-col h-full group relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-blue-500 opacity-20 rounded-full blur-3xl group-hover:opacity-30 transition-opacity"></div>
            
            <div class="w-16 h-16 bg-white/10 text-white rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform relative z-10">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
            </div>
            <p class="text-blue-300 font-bold text-xs tracking-widest uppercase mb-3 relative z-10">Master of Computer Applications</p>
            <h3 class="font-serif text-4xl font-bold text-white mb-6 leading-tight relative z-10">MCA Program</h3>
            
            <ul class="space-y-4 text-white/80 font-medium mb-10 flex-1 relative z-10">
              <li class="flex items-start gap-3"><span class="text-blue-300 font-bold uppercase w-32 tracking-wider text-xs pt-1">Duration</span><span>2 Years</span></li>
              <li class="flex items-start gap-3"><span class="text-blue-300 font-bold uppercase w-32 tracking-wider text-xs pt-1">Seats</span><span>60 Seats</span></li>
              <li class="flex items-start gap-3"><span class="text-blue-300 font-bold uppercase w-32 tracking-wider text-xs pt-1">Eligibility</span><span>Any Graduate</span></li>
              <li class="flex items-start gap-3"><span class="text-blue-300 font-bold uppercase w-32 tracking-wider text-xs pt-1">Entrance</span><span>LBS Qualifying Exam</span></li>
              <li class="flex items-start gap-3"><span class="text-blue-300 font-bold uppercase w-32 tracking-wider text-xs pt-1">University</span><span>KTU</span></li>
            </ul>
            
            <a href="#admissions" class="block text-center px-8 py-4 bg-white/10 text-white border border-white/20 rounded-xl font-bold hover:bg-white/20 transition-all shadow-md hover:shadow-lg relative z-10">APPLY FOR MCA</a>
          </div>

        </div>
      </div>
    </section>

    <!-- FACULTY SECTION -->
    <section class="py-24 bg-white relative">
      <!-- Decorative element -->
      <div class="absolute -left-32 top-10 w-96 h-96 bg-rose-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10 grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Faculty Grounded in Industry</h2>
          <div class="w-16 h-1 bg-[#8A1538] rounded-full mb-8"></div>
          <p class="text-lg text-gray-600 font-medium mb-8 leading-relaxed">
            The people teaching here have spent years in marketing, finance, HR, and operations before entering academics. That experience shapes how every subject is taught.
          </p>
          
          <!-- Faculty List -->
          <div class="space-y-6">
            <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100 hover:shadow-md transition-all">
              <h4 class="font-bold text-xl text-kmct-navy mb-1">Dr. Shamla N.K <span class="text-[#8A1538] text-sm ml-2 font-semibold">Dean</span></h4>
              <p class="text-gray-500 text-sm mb-2">PhD, MBA, M.Com.</p>
              <div class="inline-flex items-center gap-1 bg-white border border-gray-200 px-3 py-1 rounded-full text-xs font-bold text-gray-600"><svg class="w-3 h-3 text-[#8A1538]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg> 21 years experience</div>
            </div>
            
            <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100 hover:shadow-md transition-all">
              <h4 class="font-bold text-xl text-kmct-navy mb-1">Dr. Shyni P <span class="text-gray-500 text-sm ml-2 font-normal">Associate Professor</span></h4>
              <p class="text-gray-500 text-sm mb-2">PhD, MBA.</p>
              <div class="inline-flex items-center gap-1 bg-white border border-gray-200 px-3 py-1 rounded-full text-xs font-bold text-gray-600"><svg class="w-3 h-3 text-[#8A1538]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg> 13 yrs academics + 6 yrs industry</div>
            </div>

            <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100 hover:shadow-md transition-all">
              <h4 class="font-bold text-xl text-kmct-navy mb-1">Mr. Hareesh H.G <span class="text-gray-500 text-sm ml-2 font-normal">Assistant Professor</span></h4>
              <p class="text-gray-500 text-sm mb-2">MBA.</p>
              <div class="inline-flex items-center gap-1 bg-white border border-gray-200 px-3 py-1 rounded-full text-xs font-bold text-gray-600"><svg class="w-3 h-3 text-[#8A1538]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg> 12 yrs academics + 8 yrs industry</div>
            </div>
            
            <p class="text-sm font-medium text-gray-500 pl-2">
              + Supported by Ms. Shirin K.C (15 yrs exp), Mr. Adharsh P, Ms. Jasmin M, Ms. Binisha K.P, and Mr. Kevin S Chittilappilly.
            </p>
          </div>
        </div>

        <div class="relative h-[600px] rounded-3xl overflow-hidden shadow-2xl border border-gray-200 group">
          <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&q=80&w=1000&h=1200" alt="Professors" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-gradient-to-t from-[#8A1538]/80 to-transparent flex items-end p-8">
            <h3 class="text-white font-serif text-3xl font-bold leading-tight drop-shadow-md">Industry Leaders,<br/>Academic Mentors.</h3>
          </div>
        </div>
      </div>
    </section>

    <!-- NETWORK INSIDE THE INDUSTRY — Premium Redesign -->
    <section class="ksb-network-section" id="network">

      <!-- Subtle data-stream background vectors -->
      <div class="ksb-bg-vectors" aria-hidden="true">
        <svg class="ksb-vector-svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
          <defs>
            <linearGradient id="streamGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#8A1538;stop-opacity:0.06"/>
              <stop offset="100%" style="stop-color:#0a2542;stop-opacity:0.04"/>
            </linearGradient>
          </defs>
          <path d="M0,200 Q360,100 720,200 T1440,200" stroke="url(#streamGrad)" stroke-width="1.5" fill="none"/>
          <path d="M0,400 Q360,300 720,400 T1440,400" stroke="url(#streamGrad)" stroke-width="1.5" fill="none"/>
          <path d="M0,600 Q360,500 720,600 T1440,600" stroke="url(#streamGrad)" stroke-width="1.5" fill="none"/>
          <path d="M200,0 Q100,450 200,900" stroke="url(#streamGrad)" stroke-width="1" fill="none"/>
          <path d="M800,0 Q700,450 800,900" stroke="url(#streamGrad)" stroke-width="1" fill="none"/>
          <path d="M1300,0 Q1200,450 1300,900" stroke="url(#streamGrad)" stroke-width="1" fill="none"/>
        </svg>
      </div>

      <div class="ksb-container">

        <!-- ═══════════════════════════════════════════
             PART 1: Placements & Network Grid
             ═══════════════════════════════════════════ -->
        <div class="ksb-grid ksb-reveal">

          <!-- LEFT: Image + Glassmorphic Stat Card -->
          <div class="ksb-image-col">

            <!-- Stacked: image behind, card overlapping bottom -->
            <div class="ksb-image-stack">

              <!-- Background image panel -->
              <div class="ksb-image-panel">
                <img
                  src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=900&q=85&auto=format&fit=crop"
                  alt="KSB professional placement network"
                  class="ksb-panel-img"
                />
                <div class="ksb-panel-overlay"></div>
              </div>

              <!-- Glassmorphic stat card — anchored to bottom of image -->
              <div class="ksb-glass-card">

                <!-- Big stat -->
                <div class="ksb-stat-row">
                  <span class="ksb-stat-number">74%</span>
                  <div class="ksb-stat-label">
                    <span class="ksb-stat-label-main">Got Placed</span>
                    <span class="ksb-stat-label-sub">Batch of 2024</span>
                  </div>
                </div>

                <!-- Package grid -->
                <div class="ksb-pkg-grid">
                  <div class="ksb-pkg-item">
                    <p class="ksb-pkg-eyebrow">Highest Package</p>
