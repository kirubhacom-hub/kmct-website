  <!-- Scroll reveal -->
  <script is:inline>
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('is-visible');
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal-on-scroll').forEach(el => revealObserver.observe(el));
  </script>

  <!-- Animated counters — same logic as home page -->
  <script is:inline>
    const statsSection = document.getElementById('about-stats-section');
    if (statsSection) {
      const counters = statsSection.querySelectorAll('[data-count]');

      function easeOutExpo(t) { return t === 1 ? 1 : 1 - Math.pow(2, -10 * t); }

      function animateCounter(el) {
        const target = parseInt(el.getAttribute('data-count'), 10);
        const suffix = el.getAttribute('data-suffix') || '';
        const duration = 1800;
        const delay = parseInt(el.closest('.stat-item')?.style.transitionDelay || '0', 10);
        let start = null;
        setTimeout(() => {
          function step(ts) {
            if (!start) start = ts;
            const progress = Math.min((ts - start) / duration, 1);
            el.textContent = Math.floor(easeOutExpo(progress) * target) + suffix;
            if (progress < 1) requestAnimationFrame(step);
            else el.textContent = target + suffix;
          }
          requestAnimationFrame(step);
        }, delay);
      }

      const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            counters.forEach(el => animateCounter(el));
            statsObserver.disconnect();
          }
        });
      }, { threshold: 0.3 });

      statsObserver.observe(statsSection);
    }
  </script>

  <!-- Timeline: Draw & Reveal -->
  <script is:inline>
    (function () {
      const timeline = document.getElementById('kmct-timeline');
      if (!timeline) return;

      const line  = timeline.querySelector('.timeline-line');
      const items = timeline.querySelectorAll('.timeline-item');
      const dots  = timeline.querySelectorAll('.timeline-dot');
      const track = timeline.querySelector('.space-y-8');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;

          // 1. Draw the line — animate to full height of the items container
          if (line && track) {
            line.style.height = track.scrollHeight + 'px';
          }

          // 2. Slide items in from the right (staggered via their own transition-delay)
          items.forEach(item => {
            item.style.opacity  = '1';
            item.style.transform = 'translateX(0)';
          });

          // 3. Pop the dots in (each has its own transition-delay already set)
          dots.forEach(dot => {
            dot.style.opacity   = '1';
            dot.style.transform = 'scale(1)';
          });

          observer.disconnect(); // run once
        });
      }, { threshold: 0.08 });

      observer.observe(timeline);
    })();
  </script>

