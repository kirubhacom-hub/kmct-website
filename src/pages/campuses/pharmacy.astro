---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT College of Pharmaceutical Sciences</title>
    <meta name="description" content="Build a Globally Aligned Career in Pharmaceutical Sciences at KMCT CPS. B.Pharm, D.Pharm and M.Pharm degrees." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">
    
    <Header />

    <!-- HERO SECTION -->
    <section class="relative overflow-hidden" style="padding-top: 120px; background-image: linear-gradient(rgba(255,255,255,0.85), rgba(255,255,255,0.85)), url('https://images.unsplash.com/photo-1585435557343-3b092031a831?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-position: center top; background-color: white;">
      
      <!-- Centered hero content -->
      <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 flex-1 lg:pb-16 max-w-5xl mx-auto animate-fade-up">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-blue-50/90 text-[#4169E1] border border-[#4169E1]/20 font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          PCI Approved Institution
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-4 max-w-5xl drop-shadow-sm">
          KMCT College of <span class="text-[#4169E1]">Pharmaceutical Sciences</span>
        </h1>
        
        <p class="text-xl sm:text-2xl font-serif text-[#4169E1] italic mb-8 drop-shadow-sm">Build a Globally Aligned Career</p>
        
        <p class="text-lg sm:text-xl text-gray-600 max-w-4xl leading-relaxed font-medium mb-12">
          Grounded in real-world clinical excellence. Under the leadership of Dr. K Moidu and Managing Trustee Dr. KM Mehboob (a renowned Neurologist), our standards are set by medical professionals.
        </p>



        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#4169E1] text-white rounded-full font-bold text-sm lg:text-base hover:bg-blue-700 transition-all duration-300 shadow-[0_0_20px_rgba(65,105,225,0.3)] hover:-translate-y-1">
            APPLY FOR 2026-27 ADMISSIONS
          </a>
          <a href="#programs" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-[#0a2542] border-2 border-[#0a2542]/10 rounded-full font-bold text-sm lg:text-base hover:border-[#0a2542]/30 hover:bg-gray-50 transition-all duration-300">
            EXPLORE PHARMACY PROGRAMS
          </a>
        </div>
      </div>

      <!-- Infinite auto-scroll image marquee -->
      <div class="relative z-10 overflow-hidden pb-0" style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);">
        <div class="marquee-track flex gap-4 w-max">
          <!-- Set 1 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1576602976047-174e57a47881?auto=format&fit=crop&q=80&w=600&h=400" alt="Lab Research" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?auto=format&fit=crop&q=80&w=600&h=400" alt="Microscope" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1579154204601-01588f351e67?auto=format&fit=crop&q=80&w=600&h=400" alt="Pharmaceuticals" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1584308666744-24d5e16541f7?auto=format&fit=crop&q=80&w=600&h=400" alt="Medicine" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1585435557343-3b092031a831?auto=format&fit=crop&q=80&w=600&h=400" alt="Chemistry" class="w-full h-full object-cover" />
          </div>
          <!-- Set 2 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1576602976047-174e57a47881?auto=format&fit=crop&q=80&w=600&h=400" alt="Lab Research" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?auto=format&fit=crop&q=80&w=600&h=400" alt="Microscope" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1579154204601-01588f351e67?auto=format&fit=crop&q=80&w=600&h=400" alt="Pharmaceuticals" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1584308666744-24d5e16541f7?auto=format&fit=crop&q=80&w=600&h=400" alt="Medicine" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1585435557343-3b092031a831?auto=format&fit=crop&q=80&w=600&h=400" alt="Chemistry" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- STATS SECTION -->
    <section class="w-full bg-kmct-navy py-16 relative z-10 overflow-hidden shadow-2xl" id="campus-stats">
      <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-[#4169E1] via-blue-400 to-[#4169E1]"></div>
      <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #ffffff 0%, transparent 70%);"></div>
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-20">
        <div class="flex items-center justify-center gap-4 sm:gap-8 mb-12">
          <div class="h-[1px] bg-gradient-to-r from-transparent to-blue-400 w-16 sm:w-32 opacity-50"></div>
          <p class="text-center text-xs sm:text-sm font-bold uppercase tracking-[0.3em] text-blue-300 m-0">KMCT Pharmaceutical Sciences — By The Numbers</p>
          <div class="h-[1px] bg-gradient-to-l from-transparent to-blue-400 w-16 sm:w-32 opacity-50"></div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-4 lg:gap-x-0 items-center lg:divide-x lg:divide-white/10">
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 0ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="60" data-suffix="">60</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">B.Pharm<br/>Seats</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 150ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="60" data-suffix="">60</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">D.Pharm<br/>Seats</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 300ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="3" data-suffix="">3</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Programs<br/>Offered</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 450ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="25" data-suffix="+">25+</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Years<br/>KMCT Legacy</span>
          </div>
        </div>
      </div>
    </section>

    <!-- EVIDENCE-BASED EDUCATION -->
    <section class="py-24 relative bg-gray-50 border-y border-gray-100">
      <div class="absolute left-0 top-0 w-64 h-64 bg-[#4169E1]/10 rounded-br-full opacity-50 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <div class="text-center mb-16">
          <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Evidence-Based Education</h2>
          <p class="text-lg text-gray-600 font-medium max-w-2xl mx-auto">
            We bridge the gap between drug manufacturing and patient care with intensive hospital-linked training.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
            <div class="w-12 h-12 bg-blue-50 text-[#4169E1] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg></div>
            <h4 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Clinical-First</h4>
            <p class="text-gray-600 font-medium text-sm">We provide intensive hospital-linked training, bridging theory and patient care.</p>
          </div>
          <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
            <div class="w-12 h-12 bg-blue-50 text-[#4169E1] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg></div>
            <h4 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Research Hub</h4>
            <p class="text-gray-600 font-medium text-sm">Dedicated zones for drug discovery, pharmacology, and advanced pharmaceutics.</p>
          </div>
          <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
            <div class="w-12 h-12 bg-blue-50 text-[#4169E1] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div>
            <h4 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Global Pipeline</h4>
            <p class="text-gray-600 font-medium text-sm">A 25-year network of alumni working in top pharmaceutical MNCs across the world.</p>
          </div>
          <div class="bg-kmct-navy p-8 rounded-3xl shadow-lg hover:-translate-y-1 transition-all text-white">
            <div class="w-12 h-12 bg-white/10 text-[#4169E1] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg></div>
            <h4 class="font-serif text-2xl font-bold mb-3">The Merit Advantage</h4>
            <p class="text-white/80 font-medium text-sm">High-ranking seats intentionally reserved for students serious about academic performance.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PROGRAMS TABLE & MENTORS -->
    <section class="py-24 relative bg-white" id="programs">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        
        <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-12 text-center">Your Future: B.Pharm & Beyond</h2>
        
        <div class="bg-white rounded-3xl shadow-[0_20px_40px_-15px_rgba(65,105,225,0.1)] border border-gray-100 overflow-hidden mb-24">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-[#4169E1] font-bold tracking-widest uppercase text-xs">
                  <th class="p-6">Program</th>
                  <th class="p-6">Duration</th>
                  <th class="p-6">Qualifications Required</th>
                  <th class="p-6">Intake</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 font-medium text-gray-700">
                <tr class="hover:bg-blue-50/30 transition-colors">
                  <td class="p-6 font-bold text-kmct-navy text-lg text-[#4169E1]">B.Pharm</td>
                  <td class="p-6">4 Years</td>
                  <td class="p-6 text-sm">10+2 (PCM/PCB) 50%</td>
                  <td class="p-6 font-bold">60 Seats</td>
                </tr>
                <tr class="hover:bg-blue-50/30 transition-colors">
                  <td class="p-6 font-bold text-kmct-navy text-lg text-[#4169E1]">D.Pharm</td>
                  <td class="p-6">2 Years</td>
                  <td class="p-6 text-sm">10+2 (PCM/PCB)</td>
                  <td class="p-6 font-bold">60 Seats</td>
                </tr>
                <tr class="hover:bg-blue-50/30 transition-colors">
                  <td class="p-6 font-bold text-kmct-navy text-lg text-[#4169E1]">M.Pharm</td>
                  <td class="p-6">2 Years</td>
                  <td class="p-6 text-sm italic">B.Pharm Aggregate</td>
                  <td class="p-6 font-bold text-gray-400">Varies</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-16 items-center flex-col-reverse">
          <div>
            <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Learning From the Experts</h2>
            <div class="w-16 h-1 bg-[#4169E1] rounded-full mb-8"></div>
            <p class="text-lg text-gray-600 font-medium leading-relaxed mb-6">
              Your learning is guided by experienced faculty including PhD holders and subject specialists across Pharmaceutics, Pharmacology, Analysis & Chemistry.
            </p>
            <div class="bg-blue-50 p-6 rounded-2xl border border-blue-100 flex gap-4 items-center">
               <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-sm text-[#4169E1]"><svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg></div>
               <div>
                 <p class="font-bold text-kmct-navy text-lg">Dr. Sujith Abraham</p>
                 <p class="text-sm text-[#4169E1] font-medium">M.Pharm, PhD</p>
               </div>
            </div>
          </div>
          <div class="relative h-[400px] rounded-[2rem] overflow-hidden shadow-2xl group border border-gray-100">
             <img src="https://images.unsplash.com/photo-1579154204601-01588f351e67?auto=format&fit=crop&q=80&w=800" alt="Professors" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
             <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-kmct-navy to-transparent h-1/2 p-8 flex flex-col justify-end">
               <span class="text-white text-sm uppercase tracking-widest font-bold">Expert Faculty</span>
             </div>
          </div>
        </div>

      </div>
    </section>

    <!-- REAL LABS. REAL LEARNING. -->
    <section class="py-24 bg-kmct-navy text-white relative overflow-hidden">
      <div class="absolute right-0 top-0 w-1/3 h-full">
         <img src="https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?auto=format&fit=crop&q=80&w=800" alt="Lab Research" class="w-full h-full object-cover opacity-20 mix-blend-screen" style="mask-image: linear-gradient(to right, transparent, black);">
      </div>

      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <h2 class="font-serif text-4xl lg:text-5xl font-bold mb-12">Real Labs. Real Learning.</h2>
        
        <div class="grid lg:grid-cols-2 gap-12">
          <div class="bg-white/10 backdrop-blur-md p-8 rounded-3xl border border-white/20">
             <h4 class="font-serif text-2xl font-bold mb-4 flex items-center gap-3"><span class="text-blue-300">▹</span> Practical Pharmacy</h4>
             <ul class="space-y-4 text-white/80 font-medium">
               <li>Well-equipped pharmaceutical labs.</li>
               <li>Hands-on experiments and formulation work.</li>
               <li>Training in drug analysis, testing, and handling protocols.</li>
               <li>Exposure to real-world applications within medical sectors.</li>
             </ul>
          </div>
          <div class="bg-[#4169E1]/80 backdrop-blur-md p-8 rounded-3xl border border-blue-400">
             <h4 class="font-serif text-2xl font-bold mb-4 flex items-center gap-3 text-white"><span class="text-blue-200">▹</span> Industry Exposure</h4>
             <ul class="space-y-4 text-white/90 font-medium">
               <li>Guaranteed internship opportunities in reputed organisations.</li>
               <li>Industry-oriented training aligning with current drug safety standards.</li>
               <li>Strong career support & guidance for higher studies (M.Pharm/PhD).</li>
               <li>Direct pipelines to pharmaceutical placement drives.</li>
             </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ADMISSIONS (CTA) -->
    <section class="py-24 bg-white relative overflow-hidden" id="admissions">
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="bg-[#f8f9fa] rounded-[2.5rem] pt-12 px-8 md:pt-20 md:px-16 overflow-hidden flex flex-col lg:flex-row items-center justify-between border border-gray-100 relative shadow-[0_20px_60px_-15px_rgba(0,0,0,0.05)]">
          
          <!-- Left side text content -->
          <div class="w-full lg:w-3/5 pb-12 md:pb-20 relative z-10 flex flex-col items-start text-left">
            
            <!-- Pill Badge -->
            <div class="inline-flex items-center gap-3 bg-white border border-gray-200 px-4 py-2 rounded-full font-medium text-sm text-gray-700 mb-8 shadow-sm">
              <span class="w-2 h-2 rounded-full bg-[#4169E1] animate-pulse"></span>
              Admissions 2026-27 <span class="text-gray-300">|</span> <span class="text-[#4169E1]">Open Now &rarr;</span>
            </div>

            <h2 class="font-serif text-5xl lg:text-7xl font-bold text-kmct-navy leading-[1.1] tracking-tight mb-6">
              Start Your Pharmacy Career.
            </h2>
            <div class="mb-10 max-w-lg">
              <p class="text-lg md:text-xl text-[#4169E1] font-medium mb-3">Confused about the entrance process or eligibility?</p>
              <p class="text-lg text-gray-600 leading-relaxed font-medium">
                Registrations for the B.Pharm and D.Pharm academic year are officially open. Our senior counselors are just a message away.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto mb-12">
              <a href="#" class="inline-flex items-center justify-center bg-kmct-navy text-white px-8 py-4 rounded-full font-bold text-base hover:bg-black transition-all shadow-[0_10px_20px_rgba(10,37,66,0.2)] hover:-translate-y-1 w-full sm:w-auto text-center">
                 Apply Now
              </a>
