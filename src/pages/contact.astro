              <p class="font-medium">0495-2295087 <span class="text-gray-300 mx-2">|</span> 8589073000</p>
            </div>
          </div>
        </div>
        <div class="w-full lg:w-1/2 min-h-[350px] lg:min-h-full bg-gray-100 relative">
          <iframe 
            src="https://maps.google.com/maps?q=KMCT+Medical+College,+Mukkam&t=&z=13&ie=UTF8&iwloc=&output=embed" 
            width="100%" height="100%" class="absolute inset-0 border-0" allowfullscreen="" loading="lazy"></iframe>
        </div>
      </div>

      <!-- Corporate Office: Pooladikunnu -->
      <div class="bg-white rounded-[2rem] shadow-xl border border-gray-100 overflow-hidden mb-12 flex flex-col lg:flex-row reveal-on-scroll">
        <div class="w-full lg:w-1/2 p-10 md:p-14 flex flex-col justify-center">
          <span class="inline-flex items-center justify-center px-4 py-1.5 rounded-md bg-blue-50 text-blue-600 font-bold text-xs uppercase tracking-widest self-start mb-6">Corporate / NHCN</span>
          <h3 class="font-serif text-3xl font-bold text-kmct-navy mb-4">Pooladikunnu, Kozhikode</h3>
          <p class="text-gray-600 mb-8 font-medium leading-relaxed">
