---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Us | KMCT - 9 Colleges, 2 Campuses, 30 Years</title>
  <meta name="description" content="About KMCT Kallanthode & Pooladikunnu — Founded in 1994 by Dr. K. Moidu. 9 AICTE-approved colleges in Kozhikode. Engineering, Nursing, Pharmacy, Architecture and more." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    @keyframes heroSlide {
      0%   { opacity: 0; }
      4%   { opacity: 0.2; }
      20%  { opacity: 0.2; }
      24%  { opacity: 0; }
      100% { opacity: 0; }
    }
    .hero-slide {
      opacity: 0;
      animation: heroSlide 25s infinite;
    }
  </style>
</head>
<body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">

  <Header activePage="about" />

  <!-- ═══════════════════════════════════════
       HERO — matches home page style
  ═══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-white" style="padding-top: 120px;">

    <!-- Hero image slider — crossfade at 20% opacity -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <!-- Campus building / entrance -->
      <img src="https://images.unsplash.com/photo-1562774053-701939374585?auto=format&fit=crop&w=1400&h=900&q=70" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 0s;" alt="" />
      <!-- Lush green campus grounds -->
      <img src="https://images.unsplash.com/photo-1592280771190-3e2e4d571952?auto=format&fit=crop&w=1400&h=900&q=70" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 5s;" alt="" />
      <!-- Engineering / science lecture hall -->
      <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?auto=format&fit=crop&w=1400&h=900&q=70" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 10s;" alt="" />
      <!-- Students on campus steps / common area -->
      <img src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&w=1400&h=900&q=70" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 15s;" alt="" />
      <!-- College corridor / walkway -->
      <img src="https://images.unsplash.com/photo-1498243691581-b145c3f54a5a?auto=format&fit=crop&w=1400&h=900&q=70" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 20s;" alt="" />
    </div>
    <!-- Fade edges so text stays crisp -->
    <div class="absolute inset-0 bg-gradient-to-b from-white/60 via-white/50 to-white/70 pointer-events-none"></div>
    
    <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 pb-16 max-w-4xl mx-auto animate-fade-up">

      <!-- Pill badge -->
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-teal-50/90 text-teal-800 border border-teal-200 font-bold text-xs tracking-widest uppercase shadow-sm mb-8 backdrop-blur-sm">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        AICTE Approved &middot; KTU Affiliated &middot; INC Recognised &middot; Est. 1994
      </div>

      <!-- H1 -->
      <h1 class="font-serif text-5xl sm:text-6xl lg:text-[5.5rem] font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-6">
        9 Colleges.<br/>2 Campuses.<br/>30 Years.
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-gray-600 max-w-2xl leading-relaxed font-medium mb-4">
        Built in 1994 to give students from North Kerala access to professional education — without leaving the state. Today, the KMCT group runs nine colleges across two campuses in Kozhikode.
      </p>
      <p class="text-sm font-semibold text-gray-600 mb-10">
        KTU affiliated &middot; INC recognised &middot; AICTE approved &middot; Admissions open 2026–27
      </p>

      <!-- CTA -->
      <a href="/#colleges" class="inline-flex items-center gap-2 px-10 py-4 bg-[#0a2542] text-white rounded-full font-bold text-lg hover:bg-teal-700 transition-all duration-300 shadow-2xl shadow-kmct-navy/20 hover:-translate-y-1">
        View All Colleges
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>

    </div>
  </section>

  <!-- ═══════════════════════════════════════
       STATS — same as home page (animated counters)
  ═══════════════════════════════════════ -->
  <section id="about-stats-section" class="w-full bg-kmct-navy py-24 relative z-10 overflow-hidden shadow-2xl">
    
    <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-teal-800 via-teal-400 to-teal-800"></div>
    <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #ffffff 0%, transparent 70%);"></div>

    <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-20">

      <div class="flex items-center justify-center gap-4 sm:gap-8 mb-20 reveal-on-scroll">
        <div class="h-[1px] bg-gradient-to-r from-transparent to-teal-500 w-16 sm:w-32 lg:w-48 opacity-50"></div>
        <p class="text-center text-xs sm:text-sm font-bold uppercase tracking-[0.3em] text-teal-300 m-0">
          30 Years of Building Careers in North Kerala
        </p>
        <div class="h-[1px] bg-gradient-to-l from-transparent to-teal-500 w-16 sm:w-32 lg:w-48 opacity-50"></div>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-5 gap-y-16 gap-x-4 lg:gap-x-0 items-center lg:divide-x lg:divide-white/10">

        <div class="flex flex-col items-center text-center stat-item px-4 reveal-on-scroll" style="transition-delay: 0ms;">
          <div class="relative mb-5 flex items-baseline justify-center">
            <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="30" data-suffix="+">0</span>
          </div>
          <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Years<br/>Legacy</span>
        </div>

        <div class="flex flex-col items-center text-center stat-item px-4 reveal-on-scroll" style="transition-delay: 150ms;">
          <div class="relative mb-5 flex items-baseline justify-center">
            <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="9" data-suffix="">0</span>
          </div>
          <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Institutions</span>
        </div>

        <div class="flex flex-col items-center text-center stat-item px-4 reveal-on-scroll" style="transition-delay: 300ms;">
          <div class="relative mb-5 flex items-baseline justify-center">
            <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="2" data-suffix="">0</span>
          </div>
          <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Campuses</span>
        </div>

        <div class="flex flex-col items-center text-center stat-item px-4 reveal-on-scroll" style="transition-delay: 450ms;">
          <div class="relative mb-5 flex items-baseline justify-center">
            <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="50" data-suffix="+">0</span>
          </div>
          <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Programs</span>
        </div>

        <div class="flex flex-col items-center text-center stat-item px-4 col-span-2 lg:col-span-1 reveal-on-scroll" style="transition-delay: 600ms;">
          <div class="relative mb-5 flex items-baseline justify-center">
            <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="10" data-suffix="k+">0</span>
          </div>
          <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Alumni</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       THE STORY — with side image
  ═══════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">

      <div class="flex items-center gap-4 mb-16 reveal-on-scroll">
        <div class="w-10 h-px bg-teal-500"></div>
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-teal-600">The Story</p>
      </div>

      <div class="grid lg:grid-cols-12 gap-16 items-start">
        
        <!-- Story text - LEFT -->
        <div class="lg:col-span-7 reveal-on-scroll">
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-kmct-navy mb-10 leading-tight">
            How the KMCT Group Was Built — Nine Institutions, Thirty Years, Two Campuses.
          </h2>

          <div class="space-y-6 text-gray-600 leading-relaxed text-[1.05rem] font-medium">
            <p>
              The Kunhitharuvai Memorial Charitable Trust was founded in Kozhikode in 1994 by Dr. K. Moidu — a physician who recognised that students from North Kerala had limited access to professional education without leaving the state. The first institution was a pharmacy college.
            </p>
            <p>
              Engineering came next, in 2001, at the Kallanthode campus 25 kilometres from Kozhikode city. Then a polytechnic — because the diploma route deserved the same quality of institution that engineering students received. Then an engineering college specifically for women, because an all-women technical campus serves a different need, and serves it well.
            </p>
            <p>
              The nursing college at Pooladikunnu was a response to a specific gap: government nursing seats in Kerala are heavily oversubscribed, clinical training quality varies, and families from North Kerala were sending daughters to institutions far from home. The National Hospital College of Nursing was built attached to National Hospital, Kozhikode — so that students train in a real hospital from day one.
            </p>

            <!-- Pull Quote -->
            <blockquote class="border-l-4 border-teal-500 pl-6 my-8 bg-teal-50/50 rounded-r-xl py-4 pr-4">
              <p class="font-serif text-xl text-kmct-navy font-semibold leading-snug">
                "Architecture, business management, teacher education and teacher training followed — each one added because the demand existed and no institution of adequate quality was meeting it locally."
              </p>
            </blockquote>

            <p>
              In 2015, KTU affiliation brought all engineering programmes under APJ Abdul Kalam Technological University — the same university that governs government engineering colleges in Kerala.
            </p>
            <p>
              Today, under Managing Trustee Dr. KM Mehboob, the KMCT group runs nine institutions across two campuses — all under one management, one set of standards, and one admissions number. The founding question has not changed. Every admissions season, it is still being asked — and the answer is still being built.
            </p>
          </div>
        </div>

        <!-- Side image + Timeline - RIGHT -->
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          
          <div class="rounded-3xl overflow-hidden shadow-2xl mb-10 reveal-on-scroll" style="transition-delay: 100ms;">
            <img
              src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&q=80&w=800&h=500"
              alt="KMCT College of Engineering, Kallanthode"
              class="w-full h-64 object-cover"
            />
            <div class="bg-kmct-navy p-5">
              <p class="text-white font-bold text-sm">KMCT College of Engineering, Kallanthode</p>
              <p class="text-white/60 text-xs mt-1">The flagship institution — since 2001</p>
            </div>
          </div>

          <!-- Vertical Timeline — Draw & Reveal -->
          <div class="relative" id="kmct-timeline">

            <!-- The drawing line: starts height 0, fills down on scroll -->
            <div
              class="absolute left-3 top-2 w-0.5 bg-gray-200 timeline-line"
              style="height: 0; transition: height 2s cubic-bezier(0.22, 1, 0.36, 1);"
            ></div>

            <!-- Full-height ghost track (shows faint guide before animation) -->
            <div class="absolute left-3 top-2 bottom-0 w-0.5 bg-gray-100"></div>

            <div class="space-y-8">
              {[
                { year: "1994", title: "The Trust is Founded",       desc: "Dr. K. Moidu establishes KMCT. National College of Pharmacy opens." },
                { year: "2001", title: "Engineering at Kallanthode",  desc: "KMCT College of Engineering opens — AICTE approved." },
                { year: "2004", title: "Polytechnic — A Different Path", desc: "Diploma pathway + bridge to lateral entry B.Tech." },
                { year: "[Yr]", title: "Engineering for Women",       desc: "KMCT College of Engineering for Women opens at Kallanthode." },
                { year: "[Yr]", title: "Nursing at Pooladikunnu",     desc: "National Hospital College of Nursing opens. INC recognised." },
                { year: "[Yr]", title: "Teacher Training Added",      desc: "KMCT CTE (B.Ed) and TTI (D.Ed) complete the group's full range." },
                { year: "2015", title: "KTU Affiliation",             desc: "APJ Abdul Kalam Technological University becomes the affiliating body for all engineering." },
                { year: "2025", title: "Thirty Years In",             desc: "9 colleges. 2 campuses. Thousands of graduates — across India, the Gulf, UK, and Canada." },
              ].map((item, i) => (
                <div
                  class="timeline-item relative pl-10"
                  style={`
                    opacity: 0;
                    transform: translateX(24px);
                    transition: opacity 0.55s ease, transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
                    transition-delay: ${i * 90}ms;
                  `}
                >
                  <!-- Dot — pops in slightly after the row -->
                  <div
                    class={`timeline-dot absolute top-1.5 rounded-full ring-2 ring-white
                      ${i === 7
                        ? 'left-[7px] w-3 h-3 bg-kmct-navy'
                        : 'left-[9px] w-[9px] h-[9px] bg-teal-500'}`}
                    style={`
                      opacity: 0;
                      transform: scale(0);
                      transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
                      transition-delay: ${i * 90 + 120}ms;
                    `}
                  ></div>

                  <p class={`text-xs font-bold tracking-widest mb-0.5 ${i === 7 ? 'text-kmct-navy' : 'text-teal-600'}`}>
                    {item.year}
                  </p>
                  <h4 class="font-serif text-base font-bold text-kmct-navy">{item.title}</h4>
                  <p class="text-xs text-gray-500 mt-1">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>


        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       MANAGEMENT
  ═══════════════════════════════════════ -->
  <section class="py-24 bg-kmct-light">
    <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">

      <div class="flex items-center gap-4 mb-4 reveal-on-scroll">
        <div class="w-10 h-px bg-teal-500"></div>
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-teal-600">Leadership</p>
      </div>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-kmct-navy mb-4 reveal-on-scroll">
        The Management Behind KMCT
      </h2>
      <p class="text-lg text-gray-500 font-medium mb-16 reveal-on-scroll max-w-2xl">
        The KMCT group is led by practising professionals, not career administrators.
      </p>

      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        
        <!-- Dr. KM Mehboob -->
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden group reveal-on-scroll" style="transition-delay: 100ms;">
          <div class="relative h-56 overflow-hidden bg-kmct-navy">
            <img
              src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?auto=format&fit=crop&q=80&w=800&h=400"
              alt="Dr. KM Mehboob"
              class="w-full h-full object-cover object-top opacity-40 group-hover:opacity-50 transition-opacity duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-kmct-navy/90 via-kmct-navy/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-7">
              <h3 class="font-serif text-3xl font-bold text-white leading-tight">Dr. KM Mehboob</h3>
              <p class="text-teal-300 text-xs font-bold uppercase tracking-widest mt-1">Managing Trustee</p>
            </div>
          </div>
          <div class="p-8">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Kunhitharuvai Memorial Charitable Trust</p>
            <p class="text-gray-600 leading-relaxed font-medium mb-4">
              Dr. KM Mehboob is a practising neurologist in Kozhikode and the Managing Trustee of the Kunhitharuvai Memorial Charitable Trust.
            </p>
            <p class="text-gray-600 leading-relaxed font-medium">
              Under his leadership, KMCT measures institutional performance by the career outcomes of its graduating batches. Every programme at KMCT is reviewed annually against what its graduates are doing — which is why the institution was built the way it was.
            </p>
          </div>
        </div>

        <!-- Mr. Shibu M.K. -->
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden group reveal-on-scroll" style="transition-delay: 200ms;">
          <div class="relative h-56 overflow-hidden bg-kmct-navy">
            <img
              src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=80&w=800&h=400"
              alt="Mr. Shibu M.K."
              class="w-full h-full object-cover object-top opacity-40 group-hover:opacity-50 transition-opacity duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-kmct-navy/90 via-kmct-navy/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-7">
              <h3 class="font-serif text-3xl font-bold text-white leading-tight">Mr. Shibu M.K.</h3>
              <p class="text-teal-300 text-xs font-bold uppercase tracking-widest mt-1">General Manager</p>
            </div>
          </div>
          <div class="p-8">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">KMCT Group</p>
            <p class="text-gray-600 leading-relaxed font-medium mb-4">
              As General Manager of the KMCT group, he oversees the full operations of both campuses — nine colleges, two locations, and everything that keeps them running.
            </p>
            <p class="text-gray-600 leading-relaxed font-medium">
              He has been the operational constant through every expansion KMCT has made — from the Kallanthode engineering campus to the establishment of the nursing college at Pooladikunnu.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TWO CAMPUSES
  ═══════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">

      <div class="flex items-center gap-4 mb-4 reveal-on-scroll">
        <div class="w-10 h-px bg-teal-500"></div>
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-teal-600">Locations</p>
      </div>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-kmct-navy mb-16 reveal-on-scroll">
        Two Campuses — Kallanthode and Pooladikunnu.
      </h2>

      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14">
        
        <!-- Kallanthode -->
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden reveal-on-scroll" style="transition-delay: 100ms;">
          <div class="relative h-56 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1562774053-701939374585?auto=format&fit=crop&q=80&w=800&h=400"
              alt="Kallanthode Campus"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-kmct-navy/80 to-transparent"></div>
            <div class="absolute bottom-4 left-6">
              <span class="bg-white/20 backdrop-blur-sm text-white border border-white/20 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest">Main Campus</span>
            </div>
          </div>
          <div class="p-8 lg:p-10">
            <h3 class="font-serif text-2xl font-bold text-kmct-navy mb-1">Kallanthode Campus</h3>
            <p class="text-xs font-bold text-teal-600 uppercase tracking-widest mb-5">8 Colleges</p>
            <p class="text-gray-600 font-medium mb-6 leading-relaxed">
              Located approximately 25 km from Kozhikode city, off the Kozhikode-Malappuram route. Accessible by KSRTC and private bus from Kozhikode and Malappuram.
            </p>
            <ul class="space-y-2.5 text-sm font-medium text-gray-700 mb-8">
              {["KMCT College of Engineering (Co-Ed)","KMCT College of Engineering for Women","KMCT College of Pharmacy","KMCT College of Architecture","KMCT Polytechnic College","KMCT School of Business (BBA MBA MCA)","KMCT College of Teacher Education (B.Ed)","KMCT Teachers Training Institute (D.Ed)"].map(c => (
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-teal-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  {c}
                </li>
              ))}
            </ul>
            <a href="#" class="inline-flex items-center gap-2 bg-kmct-navy text-white px-6 py-3 rounded-full font-bold text-sm hover:bg-teal-700 transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Get Directions
            </a>
          </div>
        </div>

        <!-- Pooladikunnu -->
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden reveal-on-scroll" style="transition-delay: 200ms;">
          <div class="relative h-56 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&h=400&q=80"
              alt="Pooladikunnu Nursing Campus"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-kmct-navy/80 to-transparent"></div>
            <div class="absolute bottom-4 left-6">
              <span class="bg-white/20 backdrop-blur-sm text-white border border-white/20 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest">Nursing Campus</span>
            </div>
          </div>
          <div class="p-8 lg:p-10">
            <h3 class="font-serif text-2xl font-bold text-kmct-navy mb-1">Pooladikunnu Campus</h3>
