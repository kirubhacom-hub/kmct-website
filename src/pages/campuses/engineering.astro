---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT College of Engineering (Kallanthode)</title>
    <meta name="description" content="Celebrating 25 Years of Engineering Excellence. Affiliated to KTU and approved by AICTE." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden pt-[80px]">
    
    <Header />

    <!-- HERO SECTION (Navy Blue Brand Color + Image) -->
    <section class="relative pt-32 pb-24 overflow-hidden bg-kmct-navy flex flex-col items-center justify-center text-center px-6 isolate min-h-[85vh]">
      <!-- Background Image -->
      <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="Students Hero" class="w-full h-full object-cover opacity-30 mix-blend-overlay" />
        <div class="absolute inset-0 bg-gradient-to-b from-kmct-navy/80 via-kmct-navy/90 to-kmct-navy mix-blend-normal"></div>
      </div>
      
      <div class="max-w-7xl mx-auto relative z-10 text-center flex flex-col items-center mt-auto mb-auto">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white/10 text-teal-300 border border-white/20 font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          KTU Affiliated &middot; AICTE Approved
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] text-white tracking-tight mb-4 max-w-5xl drop-shadow-md">
          KMCT College of <span class="text-teal-400">Engineering</span>
        </h1>
        
        <p class="text-xl sm:text-2xl font-serif text-teal-300 italic mb-8 drop-shadow-sm">The Original Legacy of Innovation</p>
        
        <p class="text-lg sm:text-xl text-white/90 max-w-4xl leading-relaxed font-medium mb-12">
          Celebrating 25 Years of Engineering Excellence, Globally Recognized. Established in 2001, built for students who are serious about their future. Under the leadership of Dr. K Moidu (Founder Chairman) and Dr. K M Mehboob (Managing Trustee), we have evolved into a high-tech hub that prepares students for global careers.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-teal-500 text-white rounded-full font-bold text-sm lg:text-base hover:bg-teal-400 transition-all duration-300 shadow-[0_0_20px_rgba(20,184,166,0.4)] hover:-translate-y-1">
            SECURE YOUR SEAT IN THE 2026 SILVER JUBILEE BATCH
          </a>
          <a href="https://wa.me/919745299888" target="_blank" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-transparent border-2 border-white/30 text-white rounded-full font-bold text-sm lg:text-base hover:bg-white/10 transition-all duration-300">
            TALK TO A COUNSELOR ON WHATSAPP
          </a>
        </div>
      </div>
    </section>

    <!-- HIGHLIGHTS SECTION -->
    <section class="py-24 bg-white relative z-20">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        <div class="text-center mb-16 max-w-4xl mx-auto">
          <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">A Quarter Century of Engineering Excellence</h2>
          <div class="w-24 h-1 bg-teal-500 mx-auto rounded-full mb-8"></div>
          <p class="text-lg text-gray-600 font-medium">
            Since 2001, KMCT College of Engineering has shaped thousands of engineers who now lead in industry across India and beyond. Our Silver Jubilee year marks 25 years of unwavering commitment to academic rigor and student success.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-3">5000+</h3>
            <p class="font-bold text-teal-600 text-sm tracking-wide uppercase mb-2">Graduates placed globally</p>
            <p class="text-gray-500 text-sm leading-relaxed">Engineers working across Middle East, Europe, and India.</p>
          </div>
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-3">50+</h3>
            <p class="font-bold text-teal-600 text-sm tracking-wide uppercase mb-2">Top recruiters on campus</p>
            <p class="text-gray-500 text-sm leading-relaxed">From Infosys, TCS, WIPRO, Adani, and emerging tech firms.</p>
          </div>
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-3">25</h3>
            <p class="font-bold text-teal-600 text-sm tracking-wide uppercase mb-2">Years of excellence</p>
            <p class="text-gray-500 text-sm leading-relaxed">Continuous legacy building careers since our founding in 2001.</p>
          </div>
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-3">90%</h3>
            <p class="font-bold text-teal-600 text-sm tracking-wide uppercase mb-2">Advanced faculty</p>
            <p class="text-gray-500 text-sm leading-relaxed">Ph.D. holders and industry researchers leading functional departments.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TABLES & PROGRAMS -->
    <section class="py-24 bg-kmct-light relative border-y border-gray-200" id="programs">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        <div class="text-center mb-16">
          <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Choose Your Path to a Global Career</h2>
          <p class="text-lg text-gray-600 font-medium max-w-2xl mx-auto">
            Six B.Tech specializations and multiple M.Tech streams designed to match your ambitions.
          </p>
        </div>
        
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[700px]">
              <thead>
                <tr class="bg-kmct-navy text-white text-sm font-bold tracking-widest uppercase">
                  <th class="p-6 font-sans">Course Specialization</th>
                  <th class="p-6 font-sans w-32">Duration</th>
                  <th class="p-6 font-sans">Eligibility Requirement</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 text-kmct-navy font-medium">
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Computer Science (CSE)</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Information Technology (IT)</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Robotics & AI</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Electronics & Communication</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Mechanical Engineering</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Civil Engineering</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors bg-teal-50/30">
                  <td class="p-6 font-bold text-lg">M.Tech Programs (Multiple Streams)</td>
                  <td class="p-6 text-gray-600 text-sm">2 Years</td>
                  <td class="p-6 text-gray-600 text-sm italic">GATE / B.Tech Aggregate</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- TWO-COL MENTORS & TECH ECOSYSTEM -->
    <section class="py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        
        <!-- Row 1: Mentors -->
        <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
          <div class="order-2 lg:order-1 relative rounded-3xl overflow-hidden shadow-xl aspect-square lg:aspect-auto lg:h-[500px]">
             <img src="https://images.unsplash.com/photo-1577896851231-70ef18881754?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="KMCT Global Mentors" class="w-full h-full object-cover">
          </div>
          <div class="order-1 lg:order-2 lg:pl-10">
            <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Global Mentors, Not Just Teachers</h2>
            <div class="w-16 h-1 bg-teal-500 rounded-full mb-6"></div>
            <p class="text-lg text-gray-600 leading-relaxed font-medium">
              Learn from mentors who are closely aligned with industry standards, a team of PhD holders, researchers, and experts who are recognised for their excellence in their fields. Mentors at KMCT act as professional guides bridging the gap between academia and the workplace.
            </p>
          </div>
        </div>

        <!-- Row 2: Tech Ecosystem -->
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="lg:pr-10">
            <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">The Tech Ecosystem</h2>
            <div class="w-16 h-1 bg-teal-500 rounded-full mb-6"></div>
            <p class="text-lg text-gray-600 leading-relaxed font-medium mb-8">
              Experience a campus designed for the modern engineer. At Kallanthode, the environment is as smart as the students.
            </p>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <div class="mt-1 bg-teal-100 p-2 rounded-xl text-teal-600"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"></path></svg></div>
                <div>
                  <h4 class="font-bold text-xl text-kmct-navy">Industry 4.0 Labs</h4>
                  <p class="text-gray-500">Advanced setups dedicated to AI, Robotics, and the Internet of Things (IoT).</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="mt-1 bg-teal-100 p-2 rounded-xl text-teal-600"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg></div>
                <div>
                  <h4 class="font-bold text-xl text-kmct-navy">The Knowledge Hub</h4>
                  <p class="text-gray-500">A digital-first central library guaranteeing global resource access on demand.</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="mt-1 bg-teal-100 p-2 rounded-xl text-teal-600"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4M20 12c0 2.21-3.582 4-8 4s-8-1.79-8-4M20 12c0-2.21-3.582-4-8-4s-8 1.79-8 4M4 12V8m16 4V8"></path></svg></div>
                <div>
                  <h4 class="font-bold text-xl text-kmct-navy">Campus Life</h4>
                  <p class="text-gray-500">Modern Wi-Fi enabled secure hostels alongside a world-class sports turf.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="relative rounded-3xl overflow-hidden shadow-xl aspect-square lg:aspect-auto lg:h-[500px]">
             <!-- Reusing the index.astro campus image structure or placeholder -->
             <img src="https://images.unsplash.com/photo-1543269664-76b4a2f7dda4?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Tech Ecosystem" class="w-full h-full object-cover">
          </div>
        </div>

      </div>
    </section>

    <!-- ALUMNI NETWORK & KARMA 2026 -->
    <section class="py-24 bg-kmct-navy text-white relative">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          
          <div>
            <h2 class="font-serif text-4xl lg:text-5xl font-bold mb-6">A Global Alumni Network</h2>
            <div class="w-16 h-1 bg-teal-500 rounded-full mb-6"></div>
            <p class="text-lg text-white/70 leading-relaxed font-medium mb-8">
              With 25 years of graduates, our network spans the world's leading tech hubs. We don't just place you; we launch you. Trusted by Industry Giants.
            </p>
            <p class="text-teal-400 font-bold tracking-widest uppercase text-sm mb-4">Our Top Recruiters Include</p>
            <!-- Mock Recruiter Logos via text/boxes -->
            <div class="flex flex-wrap gap-4 mt-4">
              <span class="bg-white/10 px-6 py-3 rounded-lg font-bold border border-white/20">Adani Cement</span>
              <span class="bg-white/10 px-6 py-3 rounded-lg font-bold border border-white/20">Infosys</span>
              <span class="bg-white/10 px-6 py-3 rounded-lg font-bold border border-white/20">TCS</span>
              <span class="bg-white/10 px-6 py-3 rounded-lg font-bold border border-white/20">Wipro</span>
              <span class="bg-white/10 px-6 py-3 rounded-lg font-bold border border-white/20">6D Technologies</span>
            </div>
          </div>

          <div class="bg-white/5 border border-white/10 rounded-3xl p-8 relative overflow-hidden backdrop-blur-md">
            <div class="absolute inset-0 z-0">
               <img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Karma Banner" class="w-full h-full object-cover opacity-20 mix-blend-overlay">
            </div>
            <div class="relative z-10 text-center py-12">
              <p class="text-teal-400 font-bold uppercase tracking-widest text-sm mb-4">Tech Festival</p>
              <h3 class="font-serif text-5xl font-bold mb-4">Karma 2026</h3>
              <p class="text-2xl font-serif italic text-white/90 mb-6 drop-shadow">The Legend Goes Global</p>
              <p class="text-white/80 max-w-sm mx-auto font-medium">Karma is the biggest student-run spectacle in the region. For 2026, we are dialling it up to eleven.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ADMISSIONS & CONTACT (CTA) -->
    <section class="py-24 bg-teal-50 text-center relative" id="admissions">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Take The Next Step.</h2>
        <p class="text-lg text-gray-600 mb-6 font-medium">Not sure which course fits you? Talk to our admission team today.</p>
        
        <div class="flex flex-col gap-3 font-semibold text-kmct-navy mb-12">
          <p><span class="text-teal-600">Location:</span> KMCT College of Engineering, Kallanthode, NIT Campus P.O., Kozhikode, Kerala.</p>
          <p><span class="text-teal-600">Email:</span> <a href="mailto:admissions@kmct.edu.in" class="hover:underline">admissions@kmct.edu.in</a></p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+919745299888" class="inline-flex items-center justify-center gap-3 bg-kmct-navy text-white px-8 py-5 rounded-full font-bold text-sm lg:text-base hover:bg-gray-800 transition-colors shadow-xl hover:-translate-y-1">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span class="whitespace-nowrap">Admissions Hotline: +91 974 52 99 888</span>
          </a>
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 bg-teal-600 text-white px-8 py-5 rounded-full font-bold text-sm lg:text-base hover:bg-teal-500 transition-colors shadow-xl hover:-translate-y-1">
            SECURE YOUR SEAT FOR 2026
          </a>
        </div>
      </div>
    </section>

    <Footer />
    
  </body>
</html>
