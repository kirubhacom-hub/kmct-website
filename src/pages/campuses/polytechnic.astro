---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT Polytechnic College</title>
    <meta name="description" content="Kerala's Most Complete Diploma Engineering Campus. Established in 2004, offering 10 branches." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">
    
    <Header />

    <!-- HERO SECTION -->
    <section class="relative overflow-hidden" style="padding-top: 120px; background-image: linear-gradient(rgba(255,255,255,0.85), rgba(255,255,255,0.85)), url('https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-position: center top; background-color: white;">
      
      <!-- Centered hero content -->
      <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 flex-1 lg:pb-16 max-w-5xl mx-auto animate-fade-up">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-emerald-50/90 text-[#059669] border border-[#059669]/20 font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          AICTE Approved Polytechnic Institution
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-4 max-w-5xl drop-shadow-sm">
           KMCT <span class="text-[#059669]">Polytechnic College</span>
        </h1>
        
        <p class="text-xl sm:text-2xl font-serif text-[#059669] italic mb-8 drop-shadow-sm">The Smarter Route After SSLC</p>
        
        <p class="text-lg sm:text-xl text-gray-600 max-w-4xl leading-relaxed font-medium mb-12">
          Kerala's Most Complete Diploma Engineering Campus. Established in 2004, KMCT Polytechnic College is one of Kerala's largest AICTE-approved institutions with 10 diploma branches, 1,450+ enrolled students, and an 11,000+ strong alumni network working globally.
        </p>



        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#059669] text-white rounded-full font-bold text-sm lg:text-base hover:bg-[#047857] transition-all duration-300 shadow-[0_0_20px_rgba(5,150,105,0.3)] hover:-translate-y-1">
            SECURE YOUR DIPLOMA SEAT
          </a>
          <a href="#branches" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-[#0a2542] border-2 border-[#0a2542]/10 rounded-full font-bold text-sm lg:text-base hover:border-[#0a2542]/30 hover:bg-gray-50 transition-all duration-300">
            EXPLORE 10 BRANCHES
          </a>
        </div>
      </div>

      <!-- Infinite auto-scroll image marquee overlay -->
      <div class="relative z-10 overflow-hidden pb-0" style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);">
        <div class="marquee-track flex gap-4 w-max">
          <!-- Set 1 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1552581234-26160f608093?auto=format&fit=crop&q=80&w=600&h=400" alt="Workshop" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1530124566582-a618bc2615dc?auto=format&fit=crop&q=80&w=600&h=400" alt="Machining" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1581092334651-ddf26d9a09d0?auto=format&fit=crop&q=80&w=600&h=400" alt="Tech" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1523309375637-b3f4f2347f2d?auto=format&fit=crop&q=80&w=600&h=400" alt="Working" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1502444330042-d1a1ddf971b1?auto=format&fit=crop&q=80&w=600&h=400" alt="Electronics" class="w-full h-full object-cover" />
          </div>
          <!-- Set 2 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1552581234-26160f608093?auto=format&fit=crop&q=80&w=600&h=400" alt="Workshop" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1530124566582-a618bc2615dc?auto=format&fit=crop&q=80&w=600&h=400" alt="Machining" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1581092334651-ddf26d9a09d0?auto=format&fit=crop&q=80&w=600&h=400" alt="Tech" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1523309375637-b3f4f2347f2d?auto=format&fit=crop&q=80&w=600&h=400" alt="Working" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1502444330042-d1a1ddf971b1?auto=format&fit=crop&q=80&w=600&h=400" alt="Electronics" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- STATS SECTION -->
    <section class="w-full bg-kmct-navy py-16 relative z-10 overflow-hidden shadow-2xl">
      <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-[#059669] via-emerald-400 to-[#059669]"></div>
      <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #ffffff 0%, transparent 70%);"></div>
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-20">
        <div class="flex items-center justify-center gap-4 sm:gap-8 mb-12">
          <div class="h-[1px] bg-gradient-to-r from-transparent to-emerald-400 w-16 sm:w-32 opacity-50"></div>
          <p class="text-center text-xs sm:text-sm font-bold uppercase tracking-[0.3em] text-emerald-300 m-0">KMCT Polytechnic College — By The Numbers</p>
          <div class="h-[1px] bg-gradient-to-l from-transparent to-emerald-400 w-16 sm:w-32 opacity-50"></div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-4 lg:gap-x-0 items-center lg:divide-x lg:divide-white/10">
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 0ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="10" data-suffix="">10</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Diploma<br/>Branches</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 150ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="20" data-suffix="+">20+</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Years<br/>Established</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 300ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="1450" data-suffix="+">1450+</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Students<br/>Enrolled</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 450ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="11" data-suffix="k+">11k+</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Alumni<br/>Network</span>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY NOT B.TECH — Premium 50/50 Informational Section -->
    <section class="poly-why-section">
      <div class="poly-why-container">
        <div class="poly-why-grid">

          <!-- ══ LEFT COLUMN: Text & Cards ══ -->
          <div class="poly-left-col">

            <!-- Main heading -->
            <h2 class="poly-heading">Why not just do B.Tech?</h2>

            <!-- Emerald accent line -->
            <div class="poly-accent-line"></div>

            <!-- Lead-in with left border -->
            <p class="poly-lead">
              After SSLC, most students pick the longest route. Here's the smarter one.
            </p>

            <!-- Body text -->
            <p class="poly-body">
              A normal B.Tech takes 4 years... and still sends most graduates into the job market without touching a real machine once. A Diploma from KMCT Polytechnic takes <strong>3 years</strong>. You spend those 3 years in labs, workshops, and on actual equipment.
            </p>

            <!-- Direct Hiring callout -->
            <div class="poly-hiring-row">
              <span class="poly-hiring-pill">Direct Hiring:</span>
              <span class="poly-hiring-text">Companies like Ashok Leyland, Hanon Systems, and Bridco hire diploma holders directly. Our last batch had <strong>341 students placed</strong>.</span>
            </div>

            <!-- Lateral Entry card -->
            <div class="poly-lateral-card">
              <h4 class="poly-lateral-title">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="poly-lateral-icon">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 5l5 5-5 5M2 10h16"/>
                </svg>
                Upgrade to B.Tech via Lateral Entry
              </h4>
              <p class="poly-lateral-body">Your diploma gets you straight into B.Tech Year 2 at any KTU college. You skip the foundation year entirely. Full degree. Less time. Less money.</p>
            </div>

          </div><!-- /left-col -->

          <!-- ══ RIGHT COLUMN: Floating Image Composition ══ -->
          <div class="poly-image-col">

            <!-- Image 1: top-right (back layer) -->
            <img
              src="https://images.unsplash.com/photo-1530124566582-a618bc2615dc?w=700&q=85&auto=format&fit=crop"
              alt="Mechanical tools and workshop"
              class="poly-img poly-img-back"
            />

            <!-- Image 2: bottom-left (front layer, overlaps img-1) -->
            <img
              src="https://images.unsplash.com/photo-1581092334651-ddf26d9a09d0?w=700&q=85&auto=format&fit=crop"
              alt="Students in a modern engineering lab"
              class="poly-img poly-img-front"
            />

          </div><!-- /image-col -->

        </div><!-- /grid -->
      </div><!-- /container -->

      <style>
        /* ═══════════════════════════════════════════
           POLYTECHNIC — WHY NOT B.TECH SECTION
           ═══════════════════════════════════════════ */
        .poly-why-section {
          background: #ffffff;
          padding: 5rem 0;
        }

        .poly-why-container {
          max-width: 1200px;
          margin: 0 auto;
          padding: 0 2rem;
        }

        /* ── 50/50 grid ── */
        .poly-why-grid {
          display: grid;
          grid-template-columns: 1fr;
          gap: 3rem;
        }
        @media (min-width: 768px) {
          .poly-why-grid {
            grid-template-columns: 1fr 1fr;
            gap: 5rem;
            align-items: center;
          }
        }

        /* ── LEFT COLUMN ── */
        .poly-left-col {
          display: flex;
          flex-direction: column;
        }

        .poly-heading {
          font-family: 'Fraunces', Georgia, serif;
          font-size: clamp(2rem, 4.5vw, 3.2rem);
          font-weight: 800;
          color: #0a2542;
          line-height: 1.1;
          letter-spacing: -0.02em;
          margin: 0 0 1rem;
        }

        /* Emerald green underline */
        .poly-accent-line {
          width: 60px;
          height: 4px;
          background: #059669;
          border-radius: 2px;
          margin-bottom: 2rem;
        }

        /* Lead-in — italic with left border */
        .poly-lead {
          font-size: 1rem;
          font-style: italic;
          font-weight: 600;
          color: #1e3a5f;
          border-left: 3px solid #059669;
          padding-left: 1rem;
          margin: 0 0 1.5rem;
          line-height: 1.6;
        }

        /* Body text */
        .poly-body {
          font-size: 0.95rem;
          line-height: 1.7;
          color: #4b5563;
          margin: 0 0 1.5rem;
        }
        .poly-body strong {
          color: #111827;
          font-weight: 700;
        }

        /* Direct Hiring callout row */
        .poly-hiring-row {
          display: flex;
          align-items: flex-start;
          gap: 0.6rem;
          flex-wrap: wrap;
          margin-bottom: 1.75rem;
          font-size: 0.95rem;
          line-height: 1.6;
        }
        .poly-hiring-pill {
          background: #ecfdf5;
          color: #059669;
          font-weight: 700;
          font-size: 0.78rem;
          padding: 0.25rem 0.65rem;
          border-radius: 100px;
          white-space: nowrap;
          flex-shrink: 0;
          margin-top: 2px;
        }
        .poly-hiring-text {
          color: #4b5563;
        }
        .poly-hiring-text strong {
          color: #111827;
          font-weight: 700;
        }

        /* Lateral Entry card */
        .poly-lateral-card {
          background: #f4fbf7;
          border-radius: 16px;
          padding: 1.5rem;
          transition: transform 0.25s ease, box-shadow 0.25s ease;
        }
        .poly-lateral-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        }
        .poly-lateral-title {
          font-size: 0.9rem;
          font-weight: 700;
          color: #059669;
          display: flex;
          align-items: center;
          gap: 0.5rem;
          margin: 0 0 0.6rem;
        }
        .poly-lateral-icon {
          width: 16px;
          height: 16px;
          flex-shrink: 0;
        }
        .poly-lateral-body {
          font-size: 0.875rem;
          color: #4b5563;
          line-height: 1.6;
          margin: 0;
        }

        /* ── RIGHT COLUMN — Floating Image Composition ── */
        .poly-image-col {
          position: relative;
          /* Container height sized to comfortably hold both offset images */
          height: 480px;
        }
        @media (max-width: 767px) {
          .poly-image-col {
            height: 380px;
            margin-top: 3rem;
          }
        }

        .poly-img {
          position: absolute;
          width: 70%;
          height: auto;
          border-radius: 24px;
          box-shadow: 0 24px 48px -12px rgba(0,0,0,0.1);
          object-fit: cover;
          display: block;
        }

        /* Image 1 — top-right (back layer) */
        .poly-img-back {
          top: 0;
          right: 0;
          height: 60%;
          z-index: 1;
        }

        /* Image 2 — bottom-left (front layer, overlaps img-1 by ~20%) */
        .poly-img-front {
          bottom: 0;
          left: 0;
          height: 62%;
          z-index: 2;
        }
      </style>
    </section>


    <!-- DIPLOMA BRANCHES -->
    <section class="py-24 bg-white relative" id="branches">
      <div class="absolute top-0 right-0 w-96 h-96 bg-emerald-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>

      <div class="max-w-5xl mx-auto px-6 sm:px-12 relative z-10 text-center mb-16">
        <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">10 Diploma Branches. Find Yours.</h2>
        <p class="text-lg text-gray-600 font-medium max-w-2xl mx-auto">
          KMCT Polytechnic is one of the few polytechnic colleges in Kerala offering this many specialisations under one roof giving you real choice, not a forced decision. All branches are 3 Years Duration.
        </p>
      </div>

      <div class="max-w-6xl mx-auto px-6 relative z-10 grid md:grid-cols-2 xl:grid-cols-3 gap-6">
        <!-- Branch Cards instead of a boring table -->
        <div class="bg-gray-50 border border-emerald-100 hover:border-[#059669] rounded-2xl p-8 hover:-translate-y-2 transition-all shadow-sm group">
           <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#059669] mb-6 shadow-sm group-hover:bg-[#059669] group-hover:text-white transition-colors"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></div>
           <h3 class="font-serif text-xl font-bold text-kmct-navy mb-2">Mechanical Engineering</h3>
           <p class="text-gray-500 font-medium text-sm mb-4">120 Seats &middot; 3 Years</p>
        </div>
        
        <div class="bg-gray-50 border border-emerald-100 hover:border-[#059669] rounded-2xl p-8 hover:-translate-y-2 transition-all shadow-sm group">
           <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#059669] mb-6 shadow-sm group-hover:bg-[#059669] group-hover:text-white transition-colors"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M15 15H3v2h12v-2zm0-8H3v2h12V7zM3 13h18v-2H3v2zm0 8h18v-2H3v2zM3 3v2h18V3H3z"/></svg></div>
           <h3 class="font-serif text-xl font-bold text-kmct-navy mb-2">Civil Engineering</h3>
           <p class="text-gray-500 font-medium text-sm mb-4">60 Seats &middot; 3 Years</p>
        </div>

        <div class="bg-gray-50 border border-emerald-100 hover:border-[#059669] rounded-2xl p-8 hover:-translate-y-2 transition-all shadow-sm group">
           <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#059669] mb-6 shadow-sm group-hover:bg-[#059669] group-hover:text-white transition-colors"><svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
           <h3 class="font-serif text-xl font-bold text-kmct-navy mb-2">Electrical & Electronics</h3>
           <p class="text-gray-500 font-medium text-sm mb-4">60 Seats &middot; 3 Years</p>
        </div>

        <div class="bg-gray-50 border border-emerald-100 hover:border-[#059669] rounded-2xl p-8 hover:-translate-y-2 transition-all shadow-sm group">
           <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#059669] mb-6 shadow-sm group-hover:bg-[#059669] group-hover:text-white transition-colors"><svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>
           <h3 class="font-serif text-xl font-bold text-kmct-navy mb-2">Electronics & Communication</h3>
           <p class="text-gray-500 font-medium text-sm mb-4">60 Seats &middot; 3 Years</p>
        </div>

        <div class="bg-gray-50 border border-emerald-100 hover:border-[#059669] rounded-2xl p-8 hover:-translate-y-2 transition-all shadow-sm group">
           <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#059669] mb-6 shadow-sm group-hover:bg-[#059669] group-hover:text-white transition-colors"><svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg></div>
           <h3 class="font-serif text-xl font-bold text-kmct-navy mb-2">Automobile Engineering</h3>
           <p class="text-gray-500 font-medium text-sm mb-4">60 Seats &middot; 3 Years</p>
        </div>

        <div class="bg-gray-50 border border-emerald-100 hover:border-[#059669] rounded-2xl p-8 hover:-translate-y-2 transition-all shadow-sm group">
           <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#059669] mb-6 shadow-sm group-hover:bg-[#059669] group-hover:text-white transition-colors"><svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div>
           <h3 class="font-serif text-xl font-bold text-kmct-navy mb-2">Computer Science & Tech</h3>
           <p class="text-gray-500 font-medium text-sm mb-4">60 Seats &middot; 3 Years</p>
        </div>

