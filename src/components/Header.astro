---
// src/components/Header.astro
// Shared navigation header used across all pages.
// Pass `activePage` prop to highlight the current page link.
interface Props {
  activePage?: 'home' | 'about' | 'admissions' | 'contact';
}
const { activePage } = Astro.props;
---

<header id="main-header" class="w-full py-6 px-4 md:px-8 flex justify-between items-center fixed top-0 z-[60] transition-all duration-300">
  <div class="flex items-center">
    <a href="/">
      <img src="/logo.png" alt="KMCT Logo" class="h-10 md:h-11 lg:h-12 object-contain filter drop-shadow-sm transition-all" id="header-logo" />
    </a>
  </div>
  <div class="flex items-center gap-3 md:gap-4 lg:gap-5 xl:gap-8">
    <a
      href="/"
      class={`hidden md:flex font-bold text-sm transition-colors ${activePage === 'home' ? 'text-teal-600' : 'text-kmct-navy hover:text-teal-600'}`}
    >Home</a>
    <a
      href="/about"
      class={`hidden md:flex font-bold text-sm transition-colors ${activePage === 'about' ? 'text-teal-600' : 'text-kmct-navy hover:text-teal-600'}`}
    >About Us</a>

    <div class="relative group hidden md:flex items-center h-full py-2">
      <button class="font-bold text-sm transition-colors text-kmct-navy group-hover:text-teal-600 flex items-center gap-1 focus:outline-none">
        Kallanthode Campuses
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 group-hover:rotate-180 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
      </button>
      <div class="absolute top-full left-0 mt-0 pt-2 w-72 invisible opacity-0 translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 z-50">
        <div class="bg-white rounded-xl shadow-xl border border-gray-100 overflow-hidden flex flex-col">
          <a href="/campuses/engineering" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">KMCT College of Engineering</a>
          <a href="/campuses/business" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">KMCT School of Business</a>
          <a href="/campuses/teacher-education" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">KMCT College of Teacher Education</a>
          <a href="/campuses/tti" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">KMCT Teacher Training Institute</a>
          <a href="/campuses/womens-engineering" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">KMCT College of Engineering for Women</a>
          <a href="/campuses/architecture" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">KMCT College of Architecture</a>
          <a href="/campuses/polytechnic" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">KMCT Polytechnic College</a>
          <a href="/campuses/pharmacy" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">KMCT College of Pharmaceutical Sciences</a>
        </div>
      </div>
    </div>

    <div class="relative group hidden md:flex items-center h-full py-2">
      <button class="font-bold text-sm transition-colors text-kmct-navy group-hover:text-[#621B75] flex items-center gap-1 focus:outline-none">
        Pooladikunnu Campus
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 group-hover:rotate-180 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
      </button>
      <div class="absolute top-full left-0 mt-0 pt-2 w-72 invisible opacity-0 translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 z-50">
        <div class="bg-white rounded-xl shadow-xl border border-gray-100 overflow-hidden flex flex-col">
          <a href="/campuses/nursing" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-[#F3E8F5] hover:text-[#621B75] transition-colors border-b border-gray-50 last:border-0">National Hospital College of Nursing</a>
        </div>
      </div>
    </div>

    <div class="relative group hidden md:flex items-center h-full py-2">
      <button class="font-bold text-sm transition-colors text-kmct-navy group-hover:text-teal-600 flex items-center gap-1 focus:outline-none">
        Campus Life
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 group-hover:rotate-180 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
      </button>
      <div class="absolute top-full left-0 mt-0 pt-2 w-56 invisible opacity-0 translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 z-50">
        <div class="bg-white rounded-xl shadow-xl border border-gray-100 overflow-hidden flex flex-col">
          <a href="/hostel" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors border-b border-gray-50 last:border-0">Hostel Life</a>
        </div>
      </div>
    </div>
    <a
      href="/contact"
      class={`hidden md:flex font-bold text-sm transition-colors ${activePage === 'contact' ? 'text-teal-600' : 'text-kmct-navy hover:text-teal-600'}`}
    >Contact Us</a>
    <a
      href="/admissions"
      class={`hidden lg:flex font-bold text-sm transition-colors ${activePage === 'admissions' ? 'text-teal-600' : 'text-kmct-navy hover:text-teal-600'}`}
    >Admissions</a>
    <a href="tel:+919745299888" class="hidden xl:flex items-center gap-2 text-sm font-bold text-kmct-navy hover:text-teal-600 transition-colors" id="desktop-phoneBtn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.076-6.975l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
      +91 974 52 99 888
    </a>
    <a href="/#colleges" class="hidden sm:inline-block bg-kmct-navy text-white text-sm font-bold px-4 lg:px-5 py-2 lg:py-2.5 rounded-full hover:bg-kmct-navy/90 transition-all duration-300 shadow-md">
      Apply Now
    </a>
    <button id="mobile-menu-btn" class="flex items-center justify-center w-10 h-10 bg-white border border-gray-200 text-kmct-navy rounded-full shadow-sm hover:bg-gray-50 transition-colors xl:hidden" aria-expanded="false" aria-label="Toggle Navigation">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
    </button>
  </div>
</header>

<!-- Fullscreen Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-white/95 backdrop-blur-md z-[55] flex flex-col justify-start items-center opacity-0 pointer-events-none transition-all duration-500 pb-20 xl:hidden overflow-y-auto pt-24">
  <nav class="flex flex-col gap-6 text-center w-full px-6">
    <a href="/" class="mobile-link text-2xl font-serif font-bold text-kmct-navy hover:text-teal-600 transition-colors">Home</a>
    <a href="/about" class="mobile-link text-2xl font-serif font-bold text-kmct-navy hover:text-teal-600 transition-colors">About Us</a>
    
    <div class="flex flex-col items-center w-full">
      <button id="mobile-pooladikunnu-btn" class="flex items-center justify-center gap-2 text-2xl font-serif font-bold text-kmct-navy hover:text-[#621B75] transition-colors w-full focus:outline-none">
        Pooladikunnu Campus
        <svg id="mobile-pooladikunnu-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
      </button>
      <div id="mobile-pooladikunnu-menu" class="hidden flex-col gap-4 mt-4 w-full bg-[#fcfafd]/80 rounded-2xl p-5 border border-purple-100 shadow-inner">
        <a href="/campuses/nursing" class="mobile-link text-base font-bold text-gray-600 hover:text-[#621B75] transition-colors">National Hospital College of Nursing</a>
      </div>
    </div>

    <div class="flex flex-col items-center w-full">
      <button id="mobile-campuslife-btn" class="flex items-center justify-center gap-2 text-2xl font-serif font-bold text-kmct-navy hover:text-teal-600 transition-colors w-full focus:outline-none">
        Campus Life
        <svg id="mobile-campuslife-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
      </button>
      <div id="mobile-campuslife-menu" class="hidden flex-col gap-4 mt-4 w-full bg-gray-50/80 rounded-2xl p-5 border border-gray-100 shadow-inner">
        <a href="/hostel" class="mobile-link text-base font-bold text-gray-600 hover:text-teal-600 transition-colors">Hostel Life</a>
      </div>
    </div>

    <a href="/contact" class="mobile-link text-2xl font-serif font-bold text-kmct-navy hover:text-teal-600 transition-colors">Contact Us</a>
    <a href="/admissions" class="mobile-link text-2xl font-serif font-bold text-kmct-navy hover:text-teal-600 transition-colors">Admissions</a>
  </nav>
  <div class="mt-12 text-center w-full px-8 pb-8">
    <p class="text-xs text-gray-500 mb-4 uppercase tracking-widest font-bold">Contact Admissions</p>
    <a href="tel:+919745299888" class="inline-flex w-full items-center justify-center gap-2 bg-teal-600 text-white px-8 py-4 rounded-full font-bold shadow-lg shadow-teal-900/50">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.076-6.975l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
      Call +91 974 52 99 888
    </a>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('main-header');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    if (header) {
      window.addEventListener('scroll', () => {
        if (mobileMenu && mobileMenu.classList.contains('opacity-100')) return;
        if (window.scrollY > 50) {
          header.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-md', 'py-4');
          header.classList.remove('py-6', 'bg-transparent');
        } else {
          header.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-md', 'py-4');
          header.classList.add('py-6', 'bg-transparent');
        }
      });
    }

    if (menuBtn && mobileMenu) {
      const toggleMenu = () => {
        const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
        menuBtn.setAttribute('aria-expanded', !isExpanded);
        if (!isExpanded) {
          document.body.style.overflow = 'hidden';
          mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
          mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
          menuBtn.innerHTML = '<svg class="w-5 h-5 text-kmct-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
        } else {
          document.body.style.overflow = '';
          mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
          mobileMenu.classList.add('opacity-0', 'pointer-events-none');
          menuBtn.innerHTML = '<svg class="w-5 h-5 text-kmct-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>';
        }
      };
      const mobileCampusLifeBtn = document.getElementById('mobile-campuslife-btn');
      const mobileCampusLifeMenu = document.getElementById('mobile-campuslife-menu');
      const mobileCampusLifeIcon = document.getElementById('mobile-campuslife-icon');

      if (mobileCampusLifeBtn && mobileCampusLifeMenu && mobileCampusLifeIcon) {
        mobileCampusLifeBtn.addEventListener('click', () => {
          mobileCampusLifeMenu.classList.toggle('hidden');
          mobileCampusLifeMenu.classList.toggle('flex');
          mobileCampusLifeIcon.classList.toggle('rotate-180');
        });
      }

      const mobileCampusesBtn = document.getElementById('mobile-campuses-btn');
      const mobileCampusesMenu = document.getElementById('mobile-campuses-menu');
      const mobileCampusesIcon = document.getElementById('mobile-campuses-icon');

      if (mobileCampusesBtn && mobileCampusesMenu && mobileCampusesIcon) {
        mobileCampusesBtn.addEventListener('click', () => {
          mobileCampusesMenu.classList.toggle('hidden');
          mobileCampusesMenu.classList.toggle('flex');
          mobileCampusesIcon.classList.toggle('rotate-180');
        });
      }

      const mobilePooladikunnuBtn = document.getElementById('mobile-pooladikunnu-btn');
      const mobilePooladikunnuMenu = document.getElementById('mobile-pooladikunnu-menu');
      const mobilePooladikunnuIcon = document.getElementById('mobile-pooladikunnu-icon');

      if (mobilePooladikunnuBtn && mobilePooladikunnuMenu && mobilePooladikunnuIcon) {
        mobilePooladikunnuBtn.addEventListener('click', () => {
          mobilePooladikunnuMenu.classList.toggle('hidden');
          mobilePooladikunnuMenu.classList.toggle('flex');
          mobilePooladikunnuIcon.classList.toggle('rotate-180');
        });
      }

      menuBtn.addEventListener('click', toggleMenu);
      mobileLinks.forEach(link => link.addEventListener('click', () => {
        if (menuBtn.getAttribute('aria-expanded') === 'true') toggleMenu();
      }));
    }
  });
</script>
