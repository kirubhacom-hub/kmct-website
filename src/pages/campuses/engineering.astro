---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT College of Engineering (Kallanthode)</title>
    <meta name="description" content="Celebrating 25 Years of Engineering Excellence. Affiliated to KTU and approved by AICTE." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">
    
    <Header />

    <!-- HERO SECTION -->
    <section class="relative overflow-hidden" style="padding-top: 120px; background-image: linear-gradient(rgba(255,255,255,0.85), rgba(255,255,255,0.85)), url('https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-position: center top; background-color: white;">
      
      <!-- Centered hero content -->
      <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 flex-1 lg:pb-16 max-w-5xl mx-auto animate-fade-up">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-teal-50/90 text-teal-800 border border-teal-200 font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          KTU Affiliated &middot; AICTE Approved
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-4 max-w-5xl drop-shadow-sm">
          KMCT College of <span class="text-teal-600">Engineering</span>
        </h1>
        
        <p class="text-xl sm:text-2xl font-serif text-teal-600 italic mb-8 drop-shadow-sm">The Original Legacy of Innovation</p>
        
        <p class="text-lg sm:text-xl text-gray-600 max-w-4xl leading-relaxed font-medium mb-12">
          Celebrating 25 Years of Engineering Excellence, Globally Recognized. Established in 2001, built for students who are serious about their future. Under the leadership of Dr. K Moidu (Founder Chairman) and Dr. K M Mehboob (Managing Trustee), we have evolved into a high-tech hub that prepares students for global careers.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#0a2542] text-white rounded-full font-bold text-sm lg:text-base hover:bg-teal-700 transition-all duration-300 shadow-[0_0_20px_rgba(10,37,66,0.2)] hover:-translate-y-1">
            SECURE YOUR SEAT IN THE 2026 SILVER JUBILEE BATCH
          </a>
          <a href="https://wa.me/919745299888" target="_blank" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-[#0a2542] border-2 border-[#0a2542]/10 rounded-full font-bold text-sm lg:text-base hover:border-[#0a2542]/30 hover:bg-gray-50 transition-all duration-300">
            TALK TO A COUNSELOR ON WHATSAPP
          </a>
        </div>
      </div>

      <!-- Infinite auto-scroll image marquee -->
      <div class="relative z-10 overflow-hidden pb-0" style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);">
        <div class="marquee-track flex gap-4 w-max">
          <!-- Set 1 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=600&h=400" alt="Robotics" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&q=80&w=600&h=400" alt="Students" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=600&h=400" alt="Architecture" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&q=80&w=600&h=400" alt="Tech" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1552581234-26160f608093?auto=format&fit=crop&q=80&w=600&h=400" alt="Workshop" class="w-full h-full object-cover" />
          </div>
          <!-- Set 2 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=600&h=400" alt="Robotics" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&q=80&w=600&h=400" alt="Students" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=600&h=400" alt="Architecture" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&q=80&w=600&h=400" alt="Tech" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1552581234-26160f608093?auto=format&fit=crop&q=80&w=600&h=400" alt="Workshop" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- HIGHLIGHTS SECTION -->
    <section class="py-24 bg-white relative z-20 overflow-hidden">
      <!-- Decorative background blur -->
      <div class="absolute -right-64 top-0 w-[500px] h-[500px] bg-teal-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">A Quarter Century of Engineering Excellence</h2>
            <div class="w-16 h-1 bg-teal-500 rounded-full mb-8"></div>
            <p class="text-lg text-gray-600 font-medium mb-12 leading-relaxed">
              Since 2001, KMCT College of Engineering has shaped thousands of engineers who now lead in industry across India and beyond. Our Silver Jubilee year marks 25 years of unwavering commitment to academic rigor and student success.
            </p>

            <div class="grid sm:grid-cols-2 gap-6">
              <div class="bg-gray-50/50 rounded-2xl p-6 border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-3">5000+</h3>
                <p class="font-bold text-teal-600 text-xs tracking-wide uppercase mb-2">Graduates globally</p>
                <p class="text-gray-500 text-sm leading-relaxed">Engineers across Middle East, Europe, and India.</p>
              </div>
              <div class="bg-gray-50/50 rounded-2xl p-6 border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-3">50+</h3>
                <p class="font-bold text-teal-600 text-xs tracking-wide uppercase mb-2">Top recruiters</p>
                <p class="text-gray-500 text-sm leading-relaxed">From Infosys, TCS, WIPRO, and emerging tech firms.</p>
              </div>
              <div class="bg-gray-50/50 rounded-2xl p-6 border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-3">25</h3>
                <p class="font-bold text-teal-600 text-xs tracking-wide uppercase mb-2">Years of excellence</p>
                <p class="text-gray-500 text-sm leading-relaxed">Continuous legacy building careers since 2001.</p>
              </div>
              <div class="bg-gray-50/50 rounded-2xl p-6 border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                <h3 class="font-serif text-4xl font-bold text-kmct-navy mb-3">90%</h3>
                <p class="font-bold text-teal-600 text-xs tracking-wide uppercase mb-2">Advanced faculty</p>
                <p class="text-gray-500 text-sm leading-relaxed">Ph.D. holders researching functional departments.</p>
              </div>
            </div>
          </div>
          
          <div class="relative h-[600px] rounded-3xl overflow-hidden shadow-xl border border-gray-100">
            <div class="absolute inset-0 grid grid-cols-2 gap-4 p-4 bg-gray-50">
              <div class="flex flex-col gap-4 pt-12">
                <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=600&h=800" alt="Robotics Lab" class="w-full h-64 object-cover rounded-2xl shadow-sm hover:scale-[1.02] transition-transform duration-500">
                <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&h=800&q=80" alt="Students" class="w-full h-80 object-cover rounded-2xl shadow-sm hover:scale-[1.02] transition-transform duration-500">
              </div>
              <div class="flex flex-col gap-4">
                <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=600&h=800" alt="Campus" class="w-full h-80 object-cover rounded-2xl shadow-sm hover:scale-[1.02] transition-transform duration-500">
                <img src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&q=80&w=600&h=800" alt="Engineering" class="w-full h-64 object-cover rounded-2xl shadow-sm hover:scale-[1.02] transition-transform duration-500">
              </div>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-kmct-navy/10 to-transparent pointer-events-none"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- TABLES & PROGRAMS -->
    <section class="py-24 relative border-y border-gray-200" id="programs" style="background-image: linear-gradient(rgba(249, 250, 251, 0.95), rgba(249, 250, 251, 0.95)), url('https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-attachment: fixed; background-position: center;">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <div class="text-center mb-16">
          <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Choose Your Path to a Global Career</h2>
          <p class="text-lg text-gray-600 font-medium max-w-2xl mx-auto">
            Six B.Tech specializations and multiple M.Tech streams designed to match your ambitions.
          </p>
        </div>

        <!-- FEATURED PROGRAM CARDS -->
        <div class="grid lg:grid-cols-3 gap-6 mb-16">
          <!-- Undergraduate Card -->
          <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-xl hover:-translate-y-2 transition-transform duration-300 flex flex-col h-full group">
            <div class="w-14 h-14 bg-teal-50 text-teal-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <p class="text-teal-600 font-bold text-xs tracking-widest uppercase mb-3">Undergraduate</p>
            <h3 class="font-serif text-2xl font-bold text-kmct-navy mb-4 leading-tight">B.Tech Computer Science and IT</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-8 flex-1">Four-year programs with merit fees starting at ₹50,000 annually for IT.</p>
            <div class="mt-auto self-start px-4 py-2 bg-gray-50 rounded-xl flex items-center gap-2 border border-gray-100 shadow-inner">
              <span class="text-kmct-navy font-bold text-lg">₹50,000</span><span class="text-xs text-gray-500 font-medium uppercase tracking-wider">/yr starting</span>
            </div>
          </div>

          <!-- Emerging Fields Card (Highlight) -->
          <div class="bg-kmct-navy rounded-3xl p-8 border border-white/10 shadow-2xl hover:-translate-y-2 transition-transform duration-300 flex flex-col h-full relative overflow-hidden group">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-teal-500 opacity-20 rounded-full blur-3xl group-hover:opacity-30 transition-opacity"></div>
            <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-blue-500 opacity-20 rounded-full blur-3xl"></div>
            
            <div class="w-14 h-14 bg-white/10 text-teal-400 rounded-2xl flex items-center justify-center mb-6 relative z-10 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <p class="text-teal-400 font-bold text-xs tracking-widest uppercase mb-3 relative z-10">Emerging Fields</p>
            <h3 class="font-serif text-2xl font-bold text-white mb-4 leading-tight relative z-10">Robotics and AI Specialization</h3>
            <p class="text-white/70 text-sm leading-relaxed mb-8 flex-1 relative z-10">Lead the future with our cutting-edge four-year program at ₹25,000 annual merit fee.</p>
            <div class="mt-auto self-start px-4 py-2 bg-white/10 rounded-xl flex items-center gap-2 border border-white/20 shadow-inner relative z-10">
              <span class="text-white font-bold text-lg">₹25,000</span><span class="text-xs text-white/50 font-medium uppercase tracking-wider">/yr merit fee</span>
            </div>
          </div>

          <!-- Core Engineering Card -->
          <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-xl hover:-translate-y-2 transition-transform duration-300 flex flex-col h-full group">
            <div class="w-14 h-14 bg-gray-50 text-gray-600 rounded-2xl flex items-center justify-center mb-6 border border-gray-200 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <p class="text-gray-500 font-bold text-xs tracking-widest uppercase mb-3">Core Engineering</p>
            <h3 class="font-serif text-2xl font-bold text-kmct-navy mb-4 leading-tight">Mechanical, Civil, and Electronics</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-8 flex-1">Traditional disciplines with modern applications, each at ₹35,000 annual merit fee.</p>
            <div class="mt-auto self-start px-4 py-2 bg-gray-50 rounded-xl flex items-center gap-2 border border-gray-100 shadow-inner">
              <span class="text-kmct-navy font-bold text-lg">₹35,000</span><span class="text-xs text-gray-500 font-medium uppercase tracking-wider">/yr merit fee</span>
            </div>
          </div>
        </div>
        
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[700px]">
              <thead>
                <tr class="bg-kmct-navy text-white text-sm font-bold tracking-widest uppercase">
                  <th class="p-6 font-sans">Course Specialization</th>
                  <th class="p-6 font-sans w-32">Duration</th>
                  <th class="p-6 font-sans">Eligibility Requirement</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 text-kmct-navy font-medium">
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Computer Science (CSE)</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Information Technology (IT)</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Robotics & AI</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Electronics & Communication</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Mechanical Engineering</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors">
                  <td class="p-6 font-bold text-lg">B.Tech Civil Engineering</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-teal-50/50 transition-colors bg-teal-50/30">
                  <td class="p-6 font-bold text-lg">M.Tech Programs (Multiple Streams)</td>
                  <td class="p-6 text-gray-600 text-sm">2 Years</td>
                  <td class="p-6 text-gray-600 text-sm italic">GATE / B.Tech Aggregate</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- TWO-COL MENTORS & TECH ECOSYSTEM -->
    <section class="py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        
        <!-- Row 1: Mentors -->
        <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
          <div class="order-2 lg:order-1 relative rounded-3xl overflow-hidden shadow-xl aspect-square lg:aspect-auto lg:h-[500px]">
             <img src="https://images.unsplash.com/photo-1577896851231-70ef18881754?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="KMCT Global Mentors" class="w-full h-full object-cover">
          </div>
          <div class="order-1 lg:order-2 lg:pl-10">
            <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Global Mentors, Not Just Teachers</h2>
            <div class="w-16 h-1 bg-teal-500 rounded-full mb-6"></div>
            <p class="text-lg text-gray-600 leading-relaxed font-medium">
              Learn from mentors who are closely aligned with industry standards, a team of PhD holders, researchers, and experts who are recognised for their excellence in their fields. Mentors at KMCT act as professional guides bridging the gap between academia and the workplace.
            </p>
          </div>
        </div>

        <!-- Row 2: Tech Ecosystem -->
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="lg:pr-10">
            <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">The Tech Ecosystem</h2>
            <div class="w-16 h-1 bg-teal-500 rounded-full mb-6"></div>
            <p class="text-lg text-gray-600 leading-relaxed font-medium mb-8">
              Experience a campus designed for the modern engineer. At Kallanthode, the environment is as smart as the students.
            </p>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <div class="mt-1 bg-teal-100 p-2 rounded-xl text-teal-600"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"></path></svg></div>
                <div>
                  <h4 class="font-bold text-xl text-kmct-navy">Industry 4.0 Labs</h4>
                  <p class="text-gray-500">Advanced setups dedicated to AI, Robotics, and the Internet of Things (IoT).</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
