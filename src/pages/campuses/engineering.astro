---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT College of Engineering (Kallanthode)</title>
    <meta name="description" content="Celebrating 25 Years of Engineering Excellence. Affiliated to KTU and approved by AICTE." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">
    
    <Header />

    <!-- HERO SECTION (Navy Blue Brand Color) -->
    <section class="relative bg-kmct-navy pt-40 pb-24 overflow-hidden">
      <!-- Background Texture/Gradient -->
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-white via-white/50 to-transparent pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10 text-center flex flex-col items-center">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white/10 text-teal-300 border border-white/20 font-bold text-xs tracking-widest uppercase shadow-sm mb-8 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          KTU Affiliated &middot; AICTE Approved
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] text-white tracking-tight mb-6 max-w-4xl drop-shadow-md">
          KMCT College of <span class="text-teal-400">Engineering</span>
        </h1>
        
        <p class="text-lg sm:text-xl text-white/80 max-w-3xl leading-relaxed font-medium mb-12">
          Celebrating 25 Years of Engineering Excellence, Globally Recognized. The Original Legacy of Innovation. Established in 2001, built for students who are serious about their future with 25+ years of academic experience.
        </p>

        <a href="tel:+919745299888" class="inline-flex items-center gap-3 px-8 py-4 bg-teal-500 text-white rounded-full font-bold text-lg hover:bg-teal-400 transition-all duration-300 shadow-[0_0_20px_rgba(20,184,166,0.4)] hover:-translate-y-1">
          Apply Now
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </section>

    <!-- HIGHLIGHTS & FEATURES SECTION -->
    <section class="py-24 bg-white relative z-20">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        <div class="text-center mb-16">
          <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Why Choose Kallanthode Campus?</h2>
          <div class="w-24 h-1 bg-teal-500 mx-auto rounded-full"></div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Highlight 1 -->
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-kmct-navy/10 rounded-xl flex items-center justify-center mb-6 text-kmct-navy">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6.75h1.5m-1.5 3h1.5m-1.5 3h1.5M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>
            </div>
            <h3 class="text-3xl font-bold text-kmct-navy mb-2">5000+</h3>
            <p class="text-gray-600 font-medium">Graduates placed globally across Middle East, Europe, and India.</p>
          </div>

          <!-- Highlight 2 -->
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-kmct-navy/10 rounded-xl flex items-center justify-center mb-6 text-kmct-navy">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6.75h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>
            </div>
            <h3 class="text-3xl font-bold text-kmct-navy mb-2">50+</h3>
            <p class="text-gray-600 font-medium">Top recruiters including Infosys, TCS, WIPRO, and Adani.</p>
          </div>

          <!-- Highlight 3 -->
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-kmct-navy/10 rounded-xl flex items-center justify-center mb-6 text-kmct-navy">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
            </div>
            <h3 class="text-3xl font-bold text-kmct-navy mb-2">25 Years</h3>
            <p class="text-gray-600 font-medium">Of continuous legacy and academic excellence since 2001.</p>
          </div>

          <!-- Highlight 4 -->
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-kmct-navy/10 rounded-xl flex items-center justify-center mb-6 text-kmct-navy">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
            </div>
            <h3 class="text-3xl font-bold text-kmct-navy mb-2">90%</h3>
            <p class="text-gray-600 font-medium">Faculty with advanced degrees and PhDs shaping your future.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KEY FEATURES ROW -->
    <section class="pb-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        <div class="bg-kmct-light rounded-3xl p-10 lg:p-14 border border-gray-200">
          <div class="grid md:grid-cols-3 gap-8 text-center divide-y md:divide-y-0 md:divide-x divide-gray-300">
            <div class="py-4 md:py-0">
              <h4 class="font-bold text-xl text-kmct-navy mb-2">Industry 4.0 Labs</h4>
              <p class="text-gray-500 font-medium">State-of-the-art technological facilities.</p>
            </div>
            <div class="py-4 md:py-0">
              <h4 class="font-bold text-xl text-kmct-navy mb-2">Global Alumni Network</h4>
              <p class="text-gray-500 font-medium">Connection to professional mentors globally.</p>
            </div>
            <div class="py-4 md:py-0">
              <h4 class="font-bold text-xl text-kmct-navy mb-2">Karma 2026</h4>
              <p class="text-gray-500 font-medium">Flagship Tech Festival and Events.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROGRAMS SECTION -->
    <section class="py-24 bg-kmct-navy relative overflow-hidden" id="programs">
      <!-- Decor text -->
      <div class="absolute -top-10 -left-10 opacity-5 select-none font-serif text-[12rem] font-bold text-white whitespace-nowrap pointer-events-none">PROGRAMS</div>
      
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <div class="flex flex-col lg:flex-row gap-16 items-start">
          
          <!-- Left side intro text -->
          <div class="lg:w-1/3">
            <h2 class="font-serif text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
              Designed For The <span class="text-teal-400">Future.</span>
            </h2>
            <p class="text-white/70 leading-relaxed font-medium mb-8">
              Choose from a diverse range of undergraduate and postgraduate streams engineered to put you ahead. Modern curriculum designed around emerging technologies and foundational engineering. 
            </p>
            <div class="bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10 mt-8">
              <p class="text-xs text-white/50 uppercase tracking-widest font-bold mb-4">Admissions Support</p>
              <a href="tel:+919745299888" class="flex items-center gap-3 text-white font-bold text-xl hover:text-teal-400 transition-colors mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.076-6.975l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                +91 974 52 99 888
              </a>
              <a href="mailto:admissions@kmct.edu.in" class="text-teal-400 hover:text-white transition-colors text-sm font-semibold">admissions@kmct.edu.in</a>
            </div>
          </div>
          
          <!-- Classes Cards/Table -->
          <div class="lg:w-2/3 flex flex-col gap-6">
            
            <!-- Program Group 1 -->
            <div class="bg-white/10 hover:bg-white/15 backdrop-blur-sm transition-colors border border-white/20 rounded-2xl p-8 flex flex-col md:flex-row md:items-center justify-between gap-6 group">
              <div>
                <h3 class="font-bold text-2xl text-white mb-2">B.Tech Emerging Technologies</h3>
                <ul class="text-white/70 font-medium space-y-1 list-disc list-inside">
                  <li>Computer Science (CSE)</li>
                  <li>Information Technology (IT)</li>
                  <li>Robotics & AI</li>
                </ul>
              </div>
              <div class="flex items-center gap-4 shri">
                <span class="px-4 py-2 bg-white/10 rounded-full text-xs font-bold text-white uppercase tracking-widest">4 Years</span>
                <span class="w-10 h-10 rounded-full bg-teal-500 text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </span>
              </div>
            </div>

            <!-- Program Group 2 -->
            <div class="bg-white/10 hover:bg-white/15 backdrop-blur-sm transition-colors border border-white/20 rounded-2xl p-8 flex flex-col md:flex-row md:items-center justify-between gap-6 group">
              <div>
                <h3 class="font-bold text-2xl text-white mb-2">B.Tech Core Engineering</h3>
                <ul class="text-white/70 font-medium space-y-1 list-disc list-inside">
                  <li>Electronics & Communication</li>
                  <li>Mechanical Engineering</li>
                  <li>Civil Engineering</li>
                </ul>
              </div>
              <div class="flex items-center gap-4 shri">
                <span class="px-4 py-2 bg-white/10 rounded-full text-xs font-bold text-white uppercase tracking-widest">4 Years</span>
                <span class="w-10 h-10 rounded-full bg-teal-500 text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </span>
              </div>
            </div>

            <!-- Program Group 3 -->
            <div class="bg-white/10 hover:bg-white/15 backdrop-blur-sm transition-colors border border-white/20 rounded-2xl p-8 flex flex-col md:flex-row md:items-center justify-between gap-6 group">
              <div>
                <h3 class="font-bold text-2xl text-white mb-2">M.Tech Programs</h3>
                <p class="text-white/70 font-medium list-inside">Multiple specializations and streams available for advanced study and research.</p>
              </div>
              <div class="flex items-center gap-4 shri">
                <span class="px-4 py-2 bg-white/10 rounded-full text-xs font-bold text-white uppercase tracking-widest">2 Years</span>
                <span class="w-10 h-10 rounded-full bg-teal-500 text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </span>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- CALL TO ACTION -->
    <section class="py-24 bg-white text-center relative">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Take The Next Step.</h2>
        <p class="text-lg text-gray-600 mb-10 font-medium">Be a part of a 25-year legacy. Connect with our admissions counselor today to guarantee your seat.</p>
        <a href="tel:+919745299888" class="inline-flex items-center justify-center gap-2 bg-kmct-navy text-white px-10 py-5 rounded-full font-bold text-lg hover:bg-gray-800 transition-colors shadow-2xl">
          Call Admissions Now
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.076-6.975l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
        </a>
      </div>
    </section>

    <Footer />
    
  </body>
</html>
