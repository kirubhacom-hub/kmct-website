---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hostel Life at KMCT | Student Residence, Kallanthode Campus, Kozhikode</title>
  <meta name="description" content="Separate boys & girls hostels at Kallanthode campus. Furnished rooms, 4 meals/day (Kerala & North Indian cuisine), 24/7 security. All-inclusive fees (1-1.5L/year)." />
  <meta name="keywords" content="KMCT hostel, Kallanthode Kozhikode student accommodation, engineering college hostel Kerala, hostel near NIT Calicut" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    @keyframes heroSlide {
      0%   { opacity: 0; }
      4%   { opacity: 0.2; }
      20%  { opacity: 0.2; }
      24%  { opacity: 0; }
      100% { opacity: 0; }
    }
    .hero-slide {
      opacity: 0;
      animation: heroSlide 25s infinite;
    }
  </style>
</head>
<body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">

  <!-- Using a placeholder activePage for campus life if needed, but not explicitly defined yet -->
  <Header />

  <!-- ════════════════════════════════════════
       HERO SECTION
  ════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-white" style="padding-top: 120px;">

    <!-- Hero image slider — crossfade at 20% opacity -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <img src="https://images.unsplash.com/photo-1555854877-bab0e564b8d5?auto=format&fit=crop&q=80&w=1920" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 0s;" alt="" />
      <img src="https://images.unsplash.com/photo-1555854877-c25dbad60161?auto=format&fit=crop&q=80&w=1920" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 5s;" alt="" />
      <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&q=80&w=1920" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 10s;" alt="" />
      <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&q=80&w=1920" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 15s;" alt="" />
      <img src="https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&q=80&w=1920" class="hero-slide absolute inset-0 w-full h-full object-cover" style="animation-delay: 20s;" alt="" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-white/65 via-white/55 to-white/70 pointer-events-none"></div>

    <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 pb-16 max-w-4xl mx-auto animate-fade-up">
      
      <!-- Key Features Pills -->
      <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-4 mb-8">
        <span class="px-5 py-2 rounded-full bg-teal-50 text-teal-800 border border-teal-200 font-bold text-xs uppercase tracking-widest backdrop-blur-sm shadow-sm">Separate Boys &amp; Girls Hostels</span>
        <span class="px-5 py-2 rounded-full bg-teal-50 text-teal-800 border border-teal-200 font-bold text-xs uppercase tracking-widest backdrop-blur-sm shadow-sm hidden sm:inline-block">Furnished Rooms</span>
        <span class="px-5 py-2 rounded-full bg-teal-50 text-teal-800 border border-teal-200 font-bold text-xs uppercase tracking-widest backdrop-blur-sm shadow-sm hidden sm:inline-block">4 Meals/Day</span>
        <span class="px-5 py-2 rounded-full bg-teal-50 text-teal-800 border border-teal-200 font-bold text-xs uppercase tracking-widest backdrop-blur-sm shadow-sm hidden lg:inline-block">24/7 Security</span>
      </div>

      <h1 class="font-serif text-5xl sm:text-6xl lg:text-[5.5rem] font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-6">
        This is where you'll <br/>
        <span class="text-teal-600 italic font-serif">actually live</span> for the next few years.
      </h1>
      
      <p class="text-lg sm:text-xl text-gray-600 max-w-2xl leading-relaxed font-medium mb-10">
        Not just a hostel. An environment that shapes your growth in Kerala's largest unified professional campus, located near NIT Calicut.
      </p>

    </div>
  </section>

  <!-- ════════════════════════════════════════
       HOSTEL VS PG (COMPARISON)
  ════════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
      
      <div class="text-center mb-16 reveal-on-scroll">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-kmct-navy mb-4">Why the Campus Hostel?</h2>
        <p class="text-gray-500 font-medium max-w-2xl mx-auto">Compare the KMCT Hostel experience directly with outside PGs to see why our campus residence is the superior choice for your study years.</p>
        <div class="w-16 h-1 bg-teal-500 rounded-full mx-auto mt-8"></div>
      </div>

      <div class="grid gap-4 max-w-5xl mx-auto reveal-on-scroll" style="transition-delay: 150ms;">
        
        <!-- Headers -->
        <div class="hidden md:grid grid-cols-12 gap-6 px-6 py-2">
          <div class="col-span-3 font-bold text-sm uppercase tracking-widest text-gray-400">Feature</div>
          <div class="col-span-5 font-bold text-sm uppercase tracking-widest text-[#621B75]">KMCT Hostel</div>
          <div class="col-span-4 font-bold text-sm uppercase tracking-widest text-gray-400 pl-4">Outside PG</div>
        </div>

        <!-- Row 1: Meals -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 items-center hover:border-purple-100 hover:shadow-md transition-all">
          <div class="md:col-span-3 font-bold text-kmct-navy text-lg mb-2 md:mb-0">Meals</div>
          <div class="md:col-span-5 flex items-center gap-3 bg-[#fcfafd] p-4 rounded-xl border border-purple-100/50">
            <div class="w-8 h-8 rounded-full bg-[#f3e8f5] text-[#621B75] flex items-center justify-center shrink-0">
               <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <p class="font-bold text-kmct-navy">4 meals/day included</p>
          </div>
          <div class="md:col-span-4 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-0 border-gray-100 pl-0 md:pl-4 flex items-center gap-3 opacity-70">
            <div class="w-8 h-8 rounded-full bg-gray-50 text-gray-400 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </div>
            <p class="text-gray-500 font-medium">Cook or pay separately</p>
          </div>
        </div>

        <!-- Row 2: Security -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 items-center hover:border-purple-100 hover:shadow-md transition-all">
          <div class="md:col-span-3 font-bold text-kmct-navy text-lg mb-2 md:mb-0">Security</div>
          <div class="md:col-span-5 flex items-center gap-3 bg-[#fcfafd] p-4 rounded-xl border border-purple-100/50">
            <div class="w-8 h-8 rounded-full bg-[#f3e8f5] text-[#621B75] flex items-center justify-center shrink-0">
               <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <p class="font-bold text-kmct-navy">24/7 security + resident warden</p>
          </div>
          <div class="md:col-span-4 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-0 border-gray-100 pl-0 md:pl-4 flex items-center gap-3 opacity-70">
            <div class="w-8 h-8 rounded-full bg-gray-50 text-gray-400 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </div>
            <p class="text-gray-500 font-medium">No guarantee</p>
          </div>
        </div>

        <!-- Row 3: Commute -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 items-center hover:border-purple-100 hover:shadow-md transition-all">
          <div class="md:col-span-3 font-bold text-kmct-navy text-lg mb-2 md:mb-0">Commute</div>
          <div class="md:col-span-5 flex items-center gap-3 bg-[#fcfafd] p-4 rounded-xl border border-purple-100/50">
            <div class="w-8 h-8 rounded-full bg-[#f3e8f5] text-[#621B75] flex items-center justify-center shrink-0">
               <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <p class="font-bold text-kmct-navy">Easy walk to campus classes</p>
          </div>
          <div class="md:col-span-4 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-0 border-gray-100 pl-0 md:pl-4 flex items-center gap-3 opacity-70">
            <div class="w-8 h-8 rounded-full bg-gray-50 text-gray-400 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </div>
            <p class="text-gray-500 font-medium">1-3 km daily commute in traffic</p>
          </div>
        </div>

        <!-- Row 4: Accountability -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 items-center hover:border-purple-100 hover:shadow-md transition-all">
          <div class="md:col-span-3 font-bold text-kmct-navy text-lg mb-2 md:mb-0">Accountability</div>
          <div class="md:col-span-5 flex items-center gap-3 bg-[#fcfafd] p-4 rounded-xl border border-purple-100/50">
            <div class="w-8 h-8 rounded-full bg-[#f3e8f5] text-[#621B75] flex items-center justify-center shrink-0">
               <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <p class="font-bold text-kmct-navy">Full parent contact &amp; warden logging</p>
          </div>
          <div class="md:col-span-4 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-0 border-gray-100 pl-0 md:pl-4 flex items-center gap-3 opacity-70">
            <div class="w-8 h-8 rounded-full bg-gray-50 text-gray-400 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </div>
            <p class="text-gray-500 font-medium">No accountability</p>
          </div>
        </div>

        <!-- Row 5: Facilities -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 items-center hover:border-purple-100 hover:shadow-md transition-all">
          <div class="md:col-span-3 font-bold text-kmct-navy text-lg mb-2 md:mb-0">Facilities</div>
          <div class="md:col-span-5 flex items-center gap-3 bg-[#fcfafd] p-4 rounded-xl border border-purple-100/50">
            <div class="w-8 h-8 rounded-full bg-[#f3e8f5] text-[#621B75] flex items-center justify-center shrink-0">
               <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <p class="font-bold text-kmct-navy">Purified water, common areas, study peers</p>
          </div>
          <div class="md:col-span-4 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-0 border-gray-100 pl-0 md:pl-4 flex items-center gap-3 opacity-70">
            <div class="w-8 h-8 rounded-full bg-gray-50 text-gray-400 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </div>
            <p class="text-gray-500 font-medium">Varies wildly; often on your own</p>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- ════════════════════════════════════════
       ROOM SPECIFICATIONS
  ════════════════════════════════════════ -->
  <section class="py-24 bg-kmct-light relative overflow-hidden">
    <!-- Decor element -->
    <div class="absolute -right-20 -top-20 w-96 h-96 bg-gray-200/50 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        
        <div class="reveal-on-scroll">
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-kmct-navy mb-6">Room Specifications</h2>
          <p class="text-gray-600 mb-8 font-medium leading-relaxed">
            Every room is designed to balance community living with personal study space. Standard rooms accommodate 2-3 students.
          </p>
          
          <div class="space-y-6">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start gap-4">
              <div class="w-10 h-10 bg-teal-50 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" /></svg>
              </div>
              <div>
                <h4 class="font-bold text-kmct-navy mb-1">Standard Furnishings</h4>
                <p class="text-sm text-gray-500 leading-relaxed">Each student gets a bed, mattress, personal study table, chair, and an almirah for secure storage. Rooms are well-ventilated with ceiling fans.</p>
              </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start gap-4">
              <div class="w-10 h-10 bg-[#f3e8f5] rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#621b75]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12 13.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" /></svg>
              </div>
              <div>
                <h4 class="font-bold text-kmct-navy mb-1">Bathroom Facilities</h4>
                <p class="text-sm text-gray-500 leading-relaxed"><strong class="text-gray-700">Women's Hostel:</strong> Rooms include attached bathrooms.<br/><strong class="text-gray-700">Men's Hostel:</strong> Serviced common bathrooms on each floor.</p>
              </div>
            </div>

            <p class="text-xs font-bold text-gray-400 bg-gray-100/50 inline-block px-4 py-2 rounded-lg">
              * Water purifiers are available on every floor.
            </p>
          </div>
        </div>

        <!-- Image composition -->
        <div class="relative reveal-on-scroll" style="transition-delay: 200ms;">
          <div class="w-full h-80 sm:h-[400px] rounded-3xl overflow-hidden shadow-2xl relative z-10">
            <img src="https://images.unsplash.com/photo-1555854877-bab0e564b8d5?auto=format&fit=crop&q=80&w=800" alt="Hostel Room" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-kmct-navy/10 mix-blend-multiply pointer-events-none"></div>
          </div>
          <!-- Fee highlight box -->
          <div class="absolute -bottom-6 -left-6 sm:-left-12 bg-teal-600 text-white p-6 sm:p-8 rounded-3xl shadow-xl z-20 max-w-[280px]">
            <p class="text-xs uppercase tracking-widest font-bold mb-2 text-teal-200">All-Inclusive Fees</p>
            <p class="text-2xl font-bold font-serif leading-tight">Accommodation + Mess Included</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       THE MESS & MEAL SCHEDULE
  ════════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
      
      <div class="text-center md:text-left mb-16 reveal-on-scroll">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-kmct-navy mb-4">The Mess Concept</h2>
        <p class="text-gray-600 font-medium max-w-2xl text-lg leading-relaxed mb-6">You won't survive on Maggi here. We take food seriously with rotating Kerala and North Indian menus including both vegetarian and non-vegetarian options.</p>
        <div class="w-16 h-1 bg-teal-500 rounded-full md:mx-0 mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 reveal-on-scroll" style="transition-delay: 150ms;">
        
        <!-- Morning -->
        <div class="bg-kmct-light rounded-2xl p-8 border border-gray-100 hover:-translate-y-1 transition-transform">
          <div class="w-10 h-10 bg-yellow-100 text-yellow-600 rounded-full flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
          </div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Morning</p>
          <h3 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Breakfast</h3>
          <p class="text-sm text-gray-600 font-medium leading-relaxed">Dosa, appam, idli, puttu, paired with egg curry or vegetarian sides (rotates daily).</p>
        </div>

        <!-- Afternoon -->
        <div class="bg-kmct-light rounded-2xl p-8 border border-gray-100 hover:-translate-y-1 transition-transform">
          <div class="w-10 h-10 bg-orange-100 text-orange-600 rounded-full flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Afternoon</p>
          <h3 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Lunch</h3>
          <p class="text-sm text-gray-600 font-medium leading-relaxed">Full Kerala meals: Rice, sambar, thoran, accompanied by fish fry or chicken.</p>
        </div>

        <!-- Evening -->
        <div class="bg-kmct-light rounded-2xl p-8 border border-gray-100 hover:-translate-y-1 transition-transform">
          <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 11.25l-3-3m0 0l-3 3m3-3v7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Evening</p>
          <h3 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Tea + Snacks</h3>
          <p class="text-sm text-gray-600 font-medium leading-relaxed">The 4 PM reset: Hot chai, classic banana fritters, or sandwiches after classes.</p>
        </div>

        <!-- Night -->
        <div class="bg-kmct-light rounded-2xl p-8 border border-gray-100 hover:-translate-y-1 transition-transform">
          <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
          </div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Night</p>
          <h3 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Dinner</h3>
          <p class="text-sm text-gray-600 font-medium leading-relaxed">Chapati, rice options, with special biryani served twice a week.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       SAFETY & MEDICAL SUPPORT
  ════════════════════════════════════════ -->
  <section class="py-24 bg-kmct-navy relative overflow-hidden">
    <!-- Texture overlay -->
