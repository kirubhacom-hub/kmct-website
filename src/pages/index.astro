---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    
    <!-- Meta Title & SEO -->
    <title>KMCT Kallanthode - B.Tech, Nursing, Pharmacy & Architecture Colleges in Kozhikode</title>
    <meta name="description" content="KMCT Kallanthode & Pooladikunnu - 9 AICTE-approved colleges in Kozhikode. B.Tech, Nursing, Pharmacy, Architecture, MCA, MBA, B.Ed, D.Ed. KTU affiliated. INC recognised. Admissions open 2026–27. Call +91 974 52 99 888." />
    
    <!-- Open Graph (Social Share) -->
    <meta property="og:title" content="KMCT Kallanthode - B.Tech, Nursing, Pharmacy & Architecture Colleges in Kozhikode" />
    <meta property="og:description" content="9 colleges. 2 campuses. 30 years. KMCT Kallanthode & Pooladikunnu - Engineering, Nursing, Pharmacy, Architecture, Management and Teaching in Kozhikode. AICTE approved. KTU affiliated. INC recognised." />
    <meta property="og:type" content="website" />
    
    <!-- Canonical -->
    <link rel="canonical" href="https://[confirmed-domain].ac.in/" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">
    
    <Header activePage="home" />

    <section class="relative overflow-hidden" style="padding-top: 120px; background-image: linear-gradient(rgba(255,255,255,0.82), rgba(255,255,255,0.82)), url('/Blog-banner-image-1.jpg'); background-size: cover; background-position: center top; background-color: white;">



      <!-- Centered hero content -->
      <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 pb-16 max-w-4xl mx-auto animate-fade-up">

        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-teal-50/90 text-teal-800 border border-teal-200 font-bold text-xs tracking-widest uppercase shadow-sm mb-8 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          AICTE Approved &middot; KTU Affiliated &middot; INC Recognised &middot; Est. 1994
        </div>

        <!-- Headline -->
        <h1 class="font-serif text-5xl sm:text-6xl lg:text-[5.5rem] font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-6">
          Your Future<br/>Starts at KMCT.
        </h1>

        <!-- Subheadline -->
        <p class="text-lg sm:text-xl text-gray-600 max-w-2xl leading-relaxed font-medium mb-4">
          9 AICTE-approved colleges in Kozhikode &mdash; B.Tech, Nursing, Pharmacy, Architecture, BBA, MBA, B.Ed &amp; D.Ed. Built to take you from your Plus Two result to the career you planned for.
        </p>
        <p class="text-sm font-semibold text-gray-600 mb-10">
          KTU affiliated &middot; INC recognised &middot; AICTE approved &middot; Admissions open 2026–27
        </p>

        <!-- Single CTA -->
        <a href="#colleges" class="inline-flex items-center gap-2 px-10 py-4 bg-[#0a2542] text-white rounded-full font-bold text-lg hover:bg-teal-700 transition-all duration-300 shadow-2xl shadow-kmct-navy/20 hover:-translate-y-1">
          Apply Now
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>

      </div>

      <!-- Infinite auto-scroll image marquee -->
      <div class="relative z-10 overflow-hidden pb-0" style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);">
        <div class="marquee-track flex gap-4 w-max">
          <!-- Set 1 (10 images) -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Engineering" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Engineering for Women" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&h=400&q=80" alt="KMCT Nursing College" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1579154204601-01588f351e67?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Pharmacy" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Architecture" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1552581234-26160f608093?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT School of Business" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Polytechnic" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Teacher Education" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&h=400&q=80" alt="KMCT Campus Students" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1544928147-79a2dbc1f389?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT TTI" class="w-full h-full object-cover" />
          </div>
          <!-- Set 2 — exact duplicate for seamless loop -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Engineering" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Engineering for Women" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&h=400&q=80" alt="KMCT Nursing College" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1579154204601-01588f351e67?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Pharmacy" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Architecture" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1552581234-26160f608093?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT School of Business" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Polytechnic" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT Teacher Education" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&h=400&q=80" alt="KMCT Campus Students" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1544928147-79a2dbc1f389?auto=format&fit=crop&q=80&w=600&h=400" alt="KMCT TTI" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>

    </section>



    <!-- 03 Stats Section — Premium Legacy Design -->
    <section id="stats-section" class="w-full bg-kmct-navy py-24 relative z-10 overflow-hidden shadow-2xl">
      
      <!-- Elegant gold/teal linear accent bar at top -->
      <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-teal-800 via-teal-400 to-teal-800"></div>

      <!-- Subtle background texture center glow -->
      <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #ffffff 0%, transparent 70%);"></div>
      
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-20">

        <!-- Elegant Section Title with flanking fade-lines -->
        <div class="flex items-center justify-center gap-4 sm:gap-8 mb-20 reveal-on-scroll">
          <div class="h-[1px] bg-gradient-to-r from-transparent to-teal-500 w-16 sm:w-32 lg:w-48 opacity-50"></div>
          <p class="text-center text-xs sm:text-sm font-bold uppercase tracking-[0.3em] text-teal-300 m-0">
            30 Years of Building Careers in North Kerala
          </p>
          <div class="h-[1px] bg-gradient-to-l from-transparent to-teal-500 w-16 sm:w-32 lg:w-48 opacity-50"></div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-5 gap-y-16 gap-x-4 lg:gap-x-0 items-center lg:divide-x lg:divide-white/10">

          <!-- Stat 1 -->
          <div class="flex flex-col items-center text-center stat-item px-4 reveal-on-scroll" style="transition-delay: 0ms;">
            <div class="relative mb-5 flex items-baseline justify-center">
              <span
                class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg"
                data-count="30"
                data-suffix="+"
              >0</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Years<br/>Legacy</span>
          </div>

          <!-- Stat 2 -->
          <div class="flex flex-col items-center text-center stat-item px-4 reveal-on-scroll" style="transition-delay: 150ms;">
            <div class="relative mb-5 flex items-baseline justify-center">
              <span
                class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg"
                data-count="9"
                data-suffix=""
              >0</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Institutions</span>
          </div>

          <!-- Stat 3 -->
          <div class="flex flex-col items-center text-center stat-item px-4 reveal-on-scroll" style="transition-delay: 300ms;">
            <div class="relative mb-5 flex items-baseline justify-center">
              <span
                class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg"
                data-count="2"
                data-suffix=""
              >0</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Campuses</span>
          </div>

          <!-- Stat 4 -->
          <div class="flex flex-col items-center text-center stat-item px-4 reveal-on-scroll" style="transition-delay: 450ms;">
            <div class="relative mb-5 flex items-baseline justify-center">
              <span
                class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg"
                data-count="50"
                data-suffix="+"
              >0</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Programs</span>
          </div>

          <!-- Stat 5 -->
          <div class="flex flex-col items-center text-center stat-item px-4 col-span-2 lg:col-span-1 reveal-on-scroll" style="transition-delay: 600ms;">
            <div class="relative mb-5 flex items-baseline justify-center">
              <span
                class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg"
                data-count="10"
                data-suffix="k+"
              >0</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Alumni</span>
          </div>

        </div>
      </div>
    </section>


    <!-- 04 The Decision Section -->
    <section class="w-full bg-kmct-light py-24 relative">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        
        <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-16 max-w-3xl reveal-on-scroll">
          Your Rank Is Out. You Have Questions. Let's Answer Them Right Now.
        </h2>

        <div class="grid lg:grid-cols-12 gap-12 items-start">
          
          <!-- LEFT COLUMN: FAQ -->
          <div class="lg:col-span-7 space-y-6">
            
            <details class="group bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden reveal-on-scroll" style="transition-delay: 0ms;">
              <summary class="flex items-center justify-between cursor-pointer p-6 font-serif text-lg font-bold text-kmct-navy list-none hover:bg-gray-50 transition-colors">
                Will my KEAM rank be enough to get into B.Tech at KMCT?
                <span class="transition group-open:rotate-180">
                  <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                The honest answer: it depends on your rank, your preferred branch, and whether you're going through the government allotment or management quota. CSE and ECE fill faster. Civil and Mechanical have more seats. The fastest way to know? Call us with your rank - our admissions team will tell you in 5 minutes exactly which branches are open to you. We don't waste your time.
              </div>
            </details>

            <details class="group bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden reveal-on-scroll" style="transition-delay: 100ms;">
              <summary class="flex items-center justify-between cursor-pointer p-6 font-serif text-lg font-bold text-kmct-navy list-none hover:bg-gray-50 transition-colors">
                What is the total fee for B.Tech at KMCT - everything included?
                <span class="transition group-open:rotate-180">
                  <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                Government allotment fee and management quota fee are different. We publish both. Total fee means tuition + development fee + exam fee. Not just the annual tuition that looks lower on paper. Scroll to the Fee section below - it's all there. If you still have questions after reading it, call us. We will not quote you a number and then surprise you with additional charges.
              </div>
            </details>

            <details class="group bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden reveal-on-scroll" style="transition-delay: 200ms;">
              <summary class="flex items-center justify-between cursor-pointer p-6 font-serif text-lg font-bold text-kmct-navy list-none hover:bg-gray-50 transition-colors">
                Is the National Hospital College of Nursing, Pooladikunnu, INC recognised? Which hospital do students train in?
                <span class="transition group-open:rotate-180">
                  <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                Yes - INC recognised. KNC recognised. KUHS affiliated. Clinical training takes place at National Hospital, Kozhikode - a real hospital with real wards, real patients, real experience from your first year. Not a simulation lab. Not just theory classes. The hospital is named, the training is structured, and yes - after this degree, the Gulf, the UK, and Canada are real destinations. Our alumni are already there.
              </div>
            </details>

            <details class="group bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden reveal-on-scroll" style="transition-delay: 300ms;">
              <summary class="flex items-center justify-between cursor-pointer p-6 font-serif text-lg font-bold text-kmct-navy list-none hover:bg-gray-50 transition-colors">
                Is there a hostel? Is it safe?
                <span class="transition group-open:rotate-180">
                  <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                Yes. Separate hostels for men and women at Kallanthode. A dedicated women's hostel at Pooladikunnu for nursing students. Resident wardens on-site - not visiting, resident. Meals included. Transport available. Parents of nursing students: the hostel is the first thing we show you when you visit, because we know it is the first thing you need to see. See full hostel details below.
              </div>
            </details>
            
          </div>

          <!-- RIGHT COLUMN: Interest Selector — navy card style -->
          <div class="lg:col-span-5 lg:sticky lg:top-32 reveal-on-scroll" style="transition-delay: 150ms;">
            <div class="bg-kmct-navy text-white rounded-2xl p-8 shadow-2xl relative overflow-hidden">
              <!-- Decorative blob -->
              <div class="absolute -right-10 -top-10 w-44 h-44 bg-kmct-engineering opacity-20 rounded-full blur-3xl pointer-events-none"></div>
              <div class="absolute -left-10 -bottom-10 w-32 h-32 bg-teal-600 opacity-10 rounded-full blur-3xl pointer-events-none"></div>

              <div class="relative z-10">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-teal-400 mb-2">Quick Navigator</p>
                <h3 class="font-serif text-2xl lg:text-3xl font-bold text-white mb-2 leading-tight">Find Your Best-Fit Programme</h3>
                <p class="text-white/70 text-sm mb-6">Pick what you're looking for — we'll take you straight there.</p>

                <ul class="space-y-2 mb-6">
                  <li>
                    <a href="#engineering" class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl bg-white/10 hover:bg-white/20 transition-all group text-sm font-semibold text-white">
                      <span class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-teal-400"></span>
                        B.Tech / Engineering
                      </span>
                      <span class="text-white/40 group-hover:text-teal-400 transition-colors text-xs">KEAM / Mgmt →</span>
                    </a>
                  </li>
                  <li>
                    <a href="#nursing" class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl bg-white/10 hover:bg-white/20 transition-all group text-sm font-semibold text-white">
                      <span class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-teal-400"></span>
                        Nursing — B.Sc / GNM / Post Basic
                      </span>
                      <span class="text-white/40 group-hover:text-teal-400 transition-colors">→</span>
                    </a>
                  </li>
                  <li>
                    <a href="#pharmacy" class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl bg-white/10 hover:bg-white/20 transition-all group text-sm font-semibold text-white">
                      <span class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-teal-400"></span>
                        Pharmacy — D.Pharm / B.Pharm
                      </span>
                      <span class="text-white/40 group-hover:text-teal-400 transition-colors">→</span>
                    </a>
                  </li>
                  <li>
                    <a href="#architecture" class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl bg-white/10 hover:bg-white/20 transition-all group text-sm font-semibold text-white">
                      <span class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-teal-400"></span>
                        Architecture — B.Arch
                      </span>
                      <span class="text-white/40 group-hover:text-teal-400 transition-colors text-xs">NATA →</span>
                    </a>
                  </li>
                  <li>
                    <a href="#business" class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl bg-white/10 hover:bg-white/20 transition-all group text-sm font-semibold text-white">
                      <span class="flex items-center gap-2">
