        <div class="w-full lg:w-1/2 p-10 md:p-14 flex flex-col justify-center">
          <span class="inline-flex items-center justify-center px-4 py-1.5 rounded-md bg-[#F3E8F5] text-[#621B75] font-bold text-xs uppercase tracking-widest self-start mb-6">Healthcare Campus</span>
