---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT College of Teacher Education, Kozhikode</title>
    <meta name="description" content="Kerala's Largest Unified Professional Campus for B.Ed. NCTE recognised and University of Calicut affiliated." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">
    
    <Header />

    <!-- HERO SECTION -->
    <section class="relative overflow-hidden" style="padding-top: 120px; background-image: linear-gradient(rgba(255,255,255,0.85), rgba(255,255,255,0.85)), url('https://images.unsplash.com/photo-1577896851231-70ef18881754?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-position: center top; background-color: white;">
      
      <!-- Centered hero content -->
      <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 flex-1 lg:pb-16 max-w-5xl mx-auto animate-fade-up">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-red-50/90 text-[#E31837] border border-[#E31837]/20 font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          NCTE Recognised &middot; University of Calicut Affiliated
        </div>

        <p class="text-xl font-serif text-[#E31837] italic mb-4 drop-shadow-sm">Kerala's Largest Unified Professional Campus</p>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-8 max-w-5xl drop-shadow-sm">
          KMCT College of <br/><span class="text-[#E31837]">Teacher Education</span>
        </h1>
        
        <p class="text-lg sm:text-xl text-gray-600 max-w-4xl leading-relaxed font-medium mb-12">
          If you are searching for a B.Ed college in Kozhikode that is NCTE recognised, University of Calicut affiliated, and valid for Kerala PSC, KTET, and TET, your search ends here. KMCT College of Teacher Education has been producing qualified teachers since 2005. A campus environment no standalone B.Ed college in Kerala can replicate.
        </p>



        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#E31837] text-white rounded-full font-bold text-sm lg:text-base hover:bg-[#c1152f] transition-all duration-300 shadow-[0_0_20px_rgba(227,24,55,0.3)] hover:-translate-y-1">
            APPLY FOR B.ED 2026-27
          </a>
          <a href="#details" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-[#0a2542] border-2 border-[#0a2542]/10 rounded-full font-bold text-sm lg:text-base hover:border-[#0a2542]/30 hover:bg-gray-50 transition-all duration-300">
            CHECK YOUR SUBJECT ELIGIBILITY
          </a>
        </div>
      </div>

      <!-- Infinite auto-scroll image marquee -->
      <div class="relative z-10 overflow-hidden pb-0" style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);">
        <div class="marquee-track flex gap-4 w-max">
          <!-- Set 1 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&q=80&w=600&h=400" alt="Students in class" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1544928147-79a2dbc1f389?auto=format&fit=crop&q=80&w=600&h=400" alt="Teacher reading" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1531545514251-b159e38c31ce?auto=format&fit=crop&q=80&w=600&h=400" alt="Teaching" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1580894732444-8ecbef79bd1d?auto=format&fit=crop&q=80&w=600&h=400" alt="School" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=600&h=400" alt="Education" class="w-full h-full object-cover" />
          </div>
          <!-- Set 2 -->
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&q=80&w=600&h=400" alt="Students in class" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1544928147-79a2dbc1f389?auto=format&fit=crop&q=80&w=600&h=400" alt="Teacher reading" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1531545514251-b159e38c31ce?auto=format&fit=crop&q=80&w=600&h=400" alt="Teaching" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1580894732444-8ecbef79bd1d?auto=format&fit=crop&q=80&w=600&h=400" alt="School" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=600&h=400" alt="Education" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- STATS SECTION -->
    <section class="w-full bg-kmct-navy py-16 relative z-10 overflow-hidden shadow-2xl">
      <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-[#E31837] via-red-400 to-[#E31837]"></div>
      <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #ffffff 0%, transparent 70%);"></div>
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-20">
        <div class="flex items-center justify-center gap-4 sm:gap-8 mb-12">
          <div class="h-[1px] bg-gradient-to-r from-transparent to-red-500 w-16 sm:w-32 opacity-50"></div>
          <p class="text-center text-xs sm:text-sm font-bold uppercase tracking-[0.3em] text-red-300 m-0">KMCT College of Teacher Education — By The Numbers</p>
          <div class="h-[1px] bg-gradient-to-l from-transparent to-red-500 w-16 sm:w-32 opacity-50"></div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-4 lg:gap-x-0 items-center lg:divide-x lg:divide-white/10">
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 0ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="20" data-suffix="">20</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Years<br/>of Trust</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 150ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="2100" data-suffix="+">2100+</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Alumni<br/>Placed</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 300ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="200" data-suffix="">200</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Current<br/>Students</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 450ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="5" data-suffix="">5</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Teaching<br/>Subjects</span>
          </div>
        </div>
      </div>
    </section>

    <!-- B.ED DETAILS SECTION -->
    <section class="py-24 relative bg-gray-50 border-y border-gray-200" id="details">
      <!-- Decor -->
      <div class="absolute left-0 top-0 w-64 h-64 bg-red-100 rounded-br-full opacity-50 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          
          <div>
            <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">20 Years of Producing Qualified Teachers</h2>
            <div class="w-16 h-1 bg-[#E31837] rounded-full mb-8"></div>
            
            <p class="text-lg text-gray-600 font-medium mb-8 leading-relaxed">
              Most graduates searching for a B.Ed college in Kozhikode have one goal: a government teaching job in Kerala. That requires a specific qualification: An NCTE recognised B.Ed from a University of Calicut affiliated institution. 
            </p>
            <p class="text-lg text-gray-600 font-medium leading-relaxed">
              Our B.Ed degree is valid for Kerala PSC teacher recruitment, KTET - Kerala Teacher Eligibility Test, TET- Teacher Eligibility Test, and aided school appointments across Kerala. This degree opens every door in Kerala's school system.
            </p>
          </div>

          <div class="bg-white rounded-3xl p-10 shadow-[0_20px_40px_-15px_rgba(227,24,55,0.1)] border border-gray-100">
            <div class="w-16 h-16 bg-red-50 text-[#E31837] rounded-2xl flex items-center justify-center mb-8 border border-red-100">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            </div>
            <h3 class="font-serif text-3xl font-bold text-kmct-navy mb-8">B.Ed - Bachelor of Education</h3>
            
            <ul class="space-y-5 text-gray-600 font-medium">
              <li class="flex items-center gap-4"><span class="text-[#E31837] font-bold uppercase w-32 tracking-wider text-xs">Duration</span><span class="bg-gray-50 px-3 py-1 rounded-md text-sm border border-gray-100">2 Years, Full-Time</span></li>
              <li class="flex items-center gap-4"><span class="text-[#E31837] font-bold uppercase w-32 tracking-wider text-xs">Total Seats</span><span class="bg-gray-50 px-3 py-1 rounded-md text-sm border border-gray-100">100 (50 Merit, 50 Management)</span></li>
              <li class="flex items-center gap-4"><span class="text-[#E31837] font-bold uppercase w-32 tracking-wider text-xs">Eligibility</span><span class="bg-gray-50 px-3 py-1 rounded-md text-sm border border-gray-100">Degree or PG in relevant subject</span></li>
              <li class="flex items-center gap-4"><span class="text-[#E31837] font-bold uppercase w-32 tracking-wider text-xs">Recognition</span><span class="bg-gray-50 px-3 py-1 rounded-md text-sm border border-gray-100">NCTE</span></li>
              <li class="flex items-center gap-4"><span class="text-[#E31837] font-bold uppercase w-32 tracking-wider text-xs">Affiliation</span><span class="bg-gray-50 px-3 py-1 rounded-md text-sm border border-gray-100">University of Calicut</span></li>
              <li class="flex items-start gap-4"><span class="text-[#E31837] font-bold uppercase w-32 tracking-wider text-xs mt-1">Valid For</span><span class="bg-gray-50 px-3 py-1 rounded-md text-sm border border-gray-100 flex-1">Kerala PSC, KTET, TET, Aided School Appointments</span></li>
            </ul>
          </div>
          
        </div>
      </div>
    </section>

    <!-- FACULTY & MARJANI -->
    <section class="py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        
        <div class="text-center mb-16">
          <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6">Learn From Subject Specialists</h2>
          <p class="text-lg text-gray-600 font-medium max-w-2xl mx-auto">
            Every faculty member holds a B.Ed and M.Ed. Several hold NET qualifications. Our specialists bring decades of teaching experience to train the next generation of educators.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-24">
          <!-- Faculty Cards -->
          <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
             <h4 class="font-bold text-xl text-kmct-navy">Areefa P M</h4>
             <p class="text-[#E31837] font-semibold text-sm mb-2">Principal</p>
             <p class="text-gray-500 text-sm mb-3">M.Sc, B.Ed, M.Ed.</p>
             <div class="mt-auto inline-flex items-center gap-2 bg-white px-3 py-1 rounded-full text-xs font-bold text-gray-600 border border-gray-200">Natural Science &middot; 30+ yrs</div>
          </div>
          <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
             <h4 class="font-bold text-xl text-kmct-navy">Ajitha A</h4>
             <p class="text-gray-500 text-sm mb-3">MA, B.Ed, M.Ed.</p>
             <div class="mt-auto inline-flex items-center gap-2 bg-white px-3 py-1 rounded-full text-xs font-bold text-gray-600 border border-gray-200">Social Science &middot; 20+ yrs</div>
          </div>
          <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
             <h4 class="font-bold text-xl text-kmct-navy">Seena T V</h4>
             <p class="text-gray-500 text-sm mb-3">MA, B.Ed, M.Ed, NET.</p>
             <div class="mt-auto inline-flex items-center gap-2 bg-white px-3 py-1 rounded-full text-xs font-bold text-gray-600 border border-gray-200">English &middot; 13+ yrs</div>
          </div>
          <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
             <h4 class="font-bold text-xl text-kmct-navy">Manuraj S B</h4>
             <p class="text-gray-500 text-sm mb-3">M.Sc, B.Ed, M.Ed.</p>
             <div class="mt-auto inline-flex items-center gap-2 bg-white px-3 py-1 rounded-full text-xs font-bold text-gray-600 border border-gray-200">Physical Science &middot; 9+ yrs</div>
          </div>
          <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
             <h4 class="font-bold text-xl text-kmct-navy">Thasneem Anwar</h4>
             <p class="text-gray-500 text-sm mb-3">M.Sc, B.Ed, M.Ed, NET.</p>
             <div class="mt-auto inline-flex items-center gap-2 bg-white px-3 py-1 rounded-full text-xs font-bold text-gray-600 border border-gray-200">Natural Science &middot; 6+ yrs</div>
          </div>
          <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
             <h4 class="font-bold text-xl text-kmct-navy">Baby Shifa U</h4>
             <p class="text-gray-500 text-sm mb-3">M.Sc, B.Ed, M.Ed.</p>
             <div class="mt-auto inline-flex items-center gap-2 bg-white px-3 py-1 rounded-full text-xs font-bold text-gray-600 border border-gray-200">Mathematics &middot; 6+ yrs</div>
          </div>
        </div>

        <!-- Campus Life & Placements — Premium 50/50 Split -->
        <div class="cte-split-block">

          <!-- ══ LEFT COLUMN: Stats & Heading ══ -->
          <div class="cte-left-col">
            <!-- Accent label -->
            <p class="cte-placement-rate">60% Placement Rate</p>

            <!-- Main heading -->
            <h3 class="cte-main-heading">
              Campus Life<br>
              <span class="cte-ampersand">&amp;</span> Placements
            </h3>

            <!-- Description -->
            <p class="cte-description">
              2,100 Alumni Already Teaching Across Kerala. 60 graduates placed in the latest cycle.
            </p>

            <!-- Mini stat pills -->
            <div class="cte-stat-pills">
              <div class="cte-stat-pill">
                <span class="cte-pill-num">100</span>
                <span class="cte-pill-label">Seats per batch</span>
              </div>
              <div class="cte-stat-pill">
                <span class="cte-pill-num">20+</span>
                <span class="cte-pill-label">Years of trust</span>
              </div>
            </div>
          </div>

          <!-- ══ RIGHT COLUMN: Video + Glass Card ══ -->
          <div class="cte-right-col">

            <!-- Full-bleed background video (image poster fallback) -->
            <video
              class="cte-video-bg"
              autoplay
              muted
              loop
              playsinline
              poster="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?auto=format&fit=crop&w=1200&q=85"
            >
              <!-- No src — poster image acts as the visual -->
            </video>

            <!-- Dark overlay -->
            <div class="cte-video-overlay"></div>

            <!-- Glassmorphic Marjani Card -->
            <div class="cte-marjani-card">
              <p class="cte-card-eyebrow">Arts Festival</p>
              <h4 class="cte-card-title"><em>Marjani</em></h4>
              <p class="cte-card-subtitle">The Arts Festival of KMCT College of Teacher Education.</p>
              <p class="cte-card-body">
                Teaching requires more than subject knowledge. It requires communication, creativity, and the ability to engage a room. Marjani is the annual arts festival entirely student-organised. The skills built here make a good teacher visible in a school and valuable in an interview.
              </p>
            </div>

          </div><!-- /right-col -->
        </div><!-- /cte-split-block -->

        <style>
          /* ═══════════════════════════════════════
             CTE CAMPUS LIFE SPLIT BLOCK
             ═══════════════════════════════════════ */
          .cte-split-block {
            display: flex;
            flex-direction: column;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(10,37,66,0.2), 0 8px 24px rgba(0,0,0,0.1);
          }
          @media (min-width: 768px) {
            .cte-split-block {
              flex-direction: row;
              min-height: 560px;
            }
          }

          /* ── LEFT COLUMN ── */
          .cte-left-col {
            background: #081c35;
            padding: 2.5rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            flex: 1;
          }
          @media (min-width: 768px) {
            .cte-left-col {
              padding: 4rem;
              width: 50%;
              flex: none;
            }
          }

          .cte-placement-rate {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.28em;
            color: #ff7b6e;
            margin: 0 0 1.5rem;
            font-variant: small-caps;
          }

          .cte-main-heading {
            font-family: 'Fraunces', Georgia, serif;
            font-size: clamp(2.2rem, 4.5vw, 3.4rem);
            font-weight: 800;
            color: #ffffff;
            line-height: 1.1;
            margin: 0 0 1.5rem;
            letter-spacing: -0.02em;
          }
          .cte-ampersand {
            font-style: italic;
            color: #ff7b6e;
            font-weight: 400;
          }

          .cte-description {
            font-size: 1.05rem;
            line-height: 1.7;
            color: rgba(255,255,255,0.75);
            margin: 0 0 2rem;
            font-weight: 400;
          }

          /* Mini stat pills */
          .cte-stat-pills {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
          }
          .cte-stat-pill {
            display: flex;
            flex-direction: column;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px;
            padding: 0.85rem 1.25rem;
            min-width: 100px;
          }
          .cte-pill-num {
            font-family: 'Fraunces', Georgia, serif;
            font-size: 1.4rem;
            font-weight: 800;
            color: #fff;
            line-height: 1;
            margin-bottom: 3px;
          }
          .cte-pill-label {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: rgba(255,255,255,0.45);
          }

          /* ── RIGHT COLUMN ── */
          .cte-right-col {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 500px;
            flex: 1;
          }
          @media (min-width: 768px) {
            .cte-right-col {
              width: 50%;
              flex: none;
              min-height: unset;
            }
          }

