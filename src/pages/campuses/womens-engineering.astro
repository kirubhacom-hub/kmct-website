---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT College of Engineering for Women (COEW)</title>
    <meta name="description" content="Kerala's Premier Women-Only Engineering Campus specializing in Biomedical Engineering and CSE." />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-kmct-light font-sans text-gray-800 overflow-x-hidden pt-[80px]">
    <Header />
    
    <style is:global>
      /* Define the unique colors for the Women's Engineering college */
      :root {
        --color-page-primary: #C2185B;   /* Deep Magenta from COEW Logo */
        --color-page-secondary: #F8BBD0; /* Soft Pink Accent */
      }

      /* --- APPLY OVERRIDES TO STANDARD COMPONENTS --- */

      /* 1. HERO SECTION */
      .hero-section {
        background-color: var(--color-page-primary) !important;
        color: white !important; 
      }

      /* 2. BUTTONS & CTA */
      .btn-primary, .cta-button {
        background-color: white !important;
        color: var(--color-page-primary) !important; 
        border: 2px solid var(--color-page-primary) !important;
        transition: all 0.3s ease;
      }
      .btn-primary:hover, .cta-button:hover {
        background-color: var(--color-page-secondary) !important; 
        color: #880E4F !important; /* Darker magenta for hover text */
        border-color: #880E4F !important;
      }

      /* 3. SUBHEADINGS & ACCENTS */
      h2.section-heading, h3.section-subheading {
        color: var(--color-page-primary) !important;
      }

      .icon-accent {
        color: var(--color-page-primary) !important;
      }

      /* 4. PROGRAM CARDS */
      .program-card {
        border-top: 4px solid var(--color-page-primary) !important;
        transition: all 0.3s ease;
      }
      
      .program-card:hover {
        border-color: #880E4F !important;
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(194, 24, 91, 0.15);
      }
      
      /* Subtle primary text color */
      .text-primary {
        color: var(--color-page-primary) !important;
      }
      
      .bg-primary-light {
        background-color: var(--color-page-secondary) !important;
      }
    </style>

    <!-- HERO SECTION -->
    <section class="hero-section relative pt-32 pb-24 overflow-hidden flex flex-col items-center justify-center text-center px-6 isolate min-h-[85vh]">
      <!-- Background Image with Overlay -->
      <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=1920&h=1080" alt="Students Hero" class="w-full h-full object-cover opacity-20 mix-blend-overlay" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--color-page-primary)]/80 to-[var(--color-page-primary)] mix-blend-normal"></div>
      </div>
      
      <div class="max-w-6xl mx-auto relative z-10 text-center flex flex-col items-center mt-auto mb-auto animate-fade-up">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white/10 text-white border border-white/30 font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-md">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          Kerala's Premier Women-Only Engineering Campus
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] text-white tracking-tight mb-6 max-w-5xl drop-shadow-md">
          Creating the Next Gen <br/>
          <span class="text-white/90 italic">Female Tech Leaders.</span>
        </h1>
        
        <p class="text-2xl sm:text-3xl font-sans font-bold text-white mb-8 tracking-wide">
          Designed for Women. Built for the World.
        </p>
        
        <p class="text-lg sm:text-xl text-white/90 max-w-4xl leading-relaxed font-medium mb-12">
          Under the leadership of Dr. K Moidu and Dr. KM Mehboob, and the academic guidance of Dr. Sabiq P V, COEW has emerged as a premier destination for students who want to lead in specialized fields like Biomedical Engineering and CSE.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="btn-primary inline-flex items-center justify-center gap-3 px-8 py-4 rounded-full font-bold text-sm lg:text-base shadow-xl hover:-translate-y-1">
            SECURE YOUR SEAT IN THE 2026 BATCH
          </a>
          <a href="https://wa.me/919745299888" target="_blank" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-transparent border-2 border-white/50 text-white rounded-full font-bold text-sm lg:text-base hover:bg-white/10 transition-all duration-300">
            TALK TO A COUNSELOR
          </a>
        </div>
      </div>
    </section>

    <!-- HIGHLIGHTS & PROGRAMS -->
    <section class="py-24 bg-white relative z-20 overflow-hidden">
      <!-- Decorative background blur -->
      <div class="absolute -left-64 top-0 w-[500px] h-[500px] bg-primary-light rounded-full blur-3xl opacity-30 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        
        <!-- NSS Highlights -->
        <div class="flex flex-col md:flex-row items-center gap-8 bg-primary-light/30 rounded-3xl p-8 mb-20 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-20 h-20 bg-white rounded-2xl flex items-center justify-center shadow-md shrink-0 border border-gray-100">
            <svg class="w-10 h-10 icon-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          </div>
          <div>
            <h3 class="section-heading font-serif text-3xl font-bold mb-3">Best NSS unit in Kerala two years running</h3>
            <p class="text-gray-600 text-lg leading-relaxed font-medium">Our award-winning NSS unit earned top honors for two consecutive years, proving our commitment to social impact and community leadership.</p>
          </div>
        </div>

        <div class="text-center mb-16">
          <h2 class="section-heading font-serif text-4xl lg:text-5xl font-bold mb-6">Our B.Tech Programs</h2>
          <div class="w-24 h-1 bg-[var(--color-page-primary)] mx-auto rounded-full mb-8"></div>
          <p class="text-lg text-gray-600 font-medium max-w-2xl mx-auto">
            Choose from four specialized engineering tracks with transparent fees and high-demand industry focus.
          </p>
        </div>

        <!-- Programs Table -->
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden mb-24 hover:shadow-2xl transition-shadow duration-500">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[700px]">
              <thead>
                <tr class="text-white text-sm font-bold tracking-widest uppercase" style="background-color: var(--color-page-primary);">
                  <th class="p-6 font-sans">Course Specialization</th>
                  <th class="p-6 font-sans w-32">Duration</th>
                  <th class="p-6 font-sans">Eligibility Requirement</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 font-medium text-gray-800">
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="p-6 font-bold text-lg text-primary">B.Tech Biomedical Engineering</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="p-6 font-bold text-lg text-primary">B.Tech Computer Science (CSE)</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="p-6 font-bold text-lg text-primary">B.Tech Civil Engineering</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors bg-primary-light/10">
                  <td class="p-6 font-bold text-lg text-primary">B.Tech Lateral Entry (LET)</td>
                  <td class="p-6 text-gray-600 text-sm">3 Years</td>
                  <td class="p-6 text-gray-600 text-sm">Merit/KMCT Poly</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- MENTORS & FACULTY CARDS -->
        <div class="mb-12">
          <div class="text-center mb-16">
            <h2 class="section-heading font-serif text-4xl lg:text-5xl font-bold mb-6">Global Mentors: Learn from the Architects of Tech</h2>
            <p class="text-lg text-gray-600 font-medium max-w-3xl mx-auto">
              Learn in an environment where mentors are approachable, supportive, and aligned with industry expectations. Real expertise. Real mentorship. Real impact.
            </p>
          </div>
          
          <div class="grid md:grid-cols-3 gap-8">
            <div class="program-card bg-white rounded-3xl p-8 shadow-lg relative h-full flex flex-col">
              <div class="absolute -top-6 left-8 bg-white p-2 rounded-2xl shadow-md border border-gray-50">
                <div class="w-12 h-12 bg-primary-light/50 rounded-xl flex items-center justify-center icon-accent font-bold text-xl">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                </div>
              </div>
              <div class="pt-8 flex-1">
                <p class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-2">Biomedical</p>
                <h4 class="font-serif text-2xl font-bold text-gray-800 mb-4">Dr. Sameera V Mohd. Sagheer</h4>
                <p class="text-gray-600 font-medium leading-relaxed">PhD-led research in medical devices and health innovation. Focusing on the intersection of tech and life sciences.</p>
              </div>
            </div>

            <div class="program-card bg-white rounded-3xl p-8 shadow-lg relative h-full flex flex-col">
              <div class="absolute -top-6 left-8 bg-white p-2 rounded-2xl shadow-md border border-gray-50">
                <div class="w-12 h-12 bg-primary-light/50 rounded-xl flex items-center justify-center icon-accent font-bold text-xl">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
                </div>
              </div>
              <div class="pt-8 flex-1">
                <p class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-2">Software</p>
                <h4 class="font-serif text-2xl font-bold text-gray-800 mb-4">Minilal M</h4>
                <p class="text-gray-600 font-medium leading-relaxed">Architecture and AI expertise shaping the next generation. Focusing on software architecture and AI breakthroughs.</p>
              </div>
            </div>

            <div class="program-card bg-white rounded-3xl p-8 shadow-lg relative h-full flex flex-col">
              <div class="absolute -top-6 left-8 bg-white p-2 rounded-2xl shadow-md border border-gray-50">
                <div class="w-12 h-12 bg-primary-light/50 rounded-xl flex items-center justify-center icon-accent font-bold text-xl">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                </div>
              </div>
              <div class="pt-8 flex-1">
                <p class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-2">Infrastructure</p>
                <h4 class="font-serif text-2xl font-bold text-gray-800 mb-4">Aparna S</h4>
                <p class="text-gray-600 font-medium leading-relaxed">Leads civil engineering with global standards. Emphasizing sustainable infrastructure and global design principles in every project.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- SAFE CAMPUS -->
    <section class="py-24 bg-gray-50 border-y border-gray-200">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="section-heading font-serif text-4xl lg:text-5xl font-bold mb-6 leading-tight">A Safe Campus.<br>A Strong Future.</h2>
            <div class="w-16 h-1 bg-[var(--color-page-primary)] rounded-full mb-8"></div>
            <p class="text-lg text-gray-600 font-medium mb-10 leading-relaxed">
              A 25km scenic drive from Kozhikode brings you to a campus that is as smart as its students.
            </p>
            
            <ul class="space-y-6">
              <li class="flex gap-4 p-4 rounded-xl hover:bg-white hover:shadow-sm transition-all border border-transparent hover:border-gray-100">
                <div class="w-12 h-12 rounded-full bg-primary-light/50 flex items-center justify-center shrink-0 mt-1">
                  <svg class="w-6 h-6 icon-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-gray-800">Specialized Healthcare Labs</h4>
                  <p class="text-gray-500 mt-2 font-medium">Industry-standard equipment for Biomedical and Electronics research.</p>
                </div>
              </li>
              <li class="flex gap-4 p-4 rounded-xl hover:bg-white hover:shadow-sm transition-all border border-transparent hover:border-gray-100">
                <div class="w-12 h-12 rounded-full bg-primary-light/50 flex items-center justify-center shrink-0 mt-1">
                  <svg class="w-6 h-6 icon-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-gray-800">Dedicated Women-Only Environment</h4>
                  <p class="text-gray-500 mt-2 font-medium">Faculty and resident wardens available on campus 24/7 for a secure atmosphere.</p>
                </div>
              </li>
              <li class="flex gap-4 p-4 rounded-xl hover:bg-white hover:shadow-sm transition-all border border-transparent hover:border-gray-100">
                <div class="w-12 h-12 rounded-full bg-primary-light/50 flex items-center justify-center shrink-0 mt-1">
                  <svg class="w-6 h-6 icon-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-gray-800">Smart Classrooms</h4>
                  <p class="text-gray-500 mt-2 font-medium">High-tech project-based learning environment built for focus.</p>
                </div>
              </li>
              <li class="flex gap-4 p-4 rounded-xl hover:bg-white hover:shadow-sm transition-all border border-transparent hover:border-gray-100">
                <div class="w-12 h-12 rounded-full bg-primary-light/50 flex items-center justify-center shrink-0 mt-1">
                  <svg class="w-6 h-6 icon-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-gray-800">Knowledge Library</h4>
                  <p class="text-gray-500 mt-2 font-medium">Modern digital learning resources and journals readily available for students.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="relative h-[650px] rounded-3xl overflow-hidden shadow-2xl p-2 bg-white">
            <img src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&q=80&w=1000&h=1200" class="w-full h-full object-cover rounded-[1.2rem]" alt="Safe Campus Environment"/>
          </div>
        </div>
      </div>
    </section>

    <!-- PLACEMENTS & CULTURE -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        
        <div class="grid lg:grid-cols-2 gap-16 items-center mb-32">
          <div class="order-2 lg:order-1 relative rounded-3xl overflow-hidden shadow-2xl p-2 bg-gray-50">
             <img src="https://images.unsplash.com/photo-1573167243872-43c6433b9d40?auto=format&fit=crop&q=80&w=1000&h=700" alt="Students Collaboration" class="w-full h-full object-cover aspect-video rounded-[1.2rem]">
             <div class="absolute inset-0 bg-gradient-to-tr from-[var(--color-page-primary)]/20 to-transparent pointer-events-none"></div>
          </div>
          <div class="order-1 lg:order-2">
            <h2 class="section-heading font-serif text-4xl lg:text-5xl font-bold mb-6">Career-Focused Training & Placements</h2>
            <div class="w-16 h-1 bg-[var(--color-page-primary)] rounded-full mb-8"></div>
            <p class="text-lg text-gray-600 font-medium mb-8 leading-relaxed">
              With a 62% placement rate in the latest cycle, our women are proving their mettle in top-tier global firms.
            </p>
            <ul class="space-y-6">
              <li class="flex gap-4">
                <svg class="w-6 h-6 icon-accent shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <p class="text-gray-700 font-medium text-lg leading-relaxed"><strong class="text-gray-900 border-b-2" style="border-color: var(--color-page-primary)">The Payoff:</strong> Graduates secured roles with salaries up to 3 LPA, starting their journey with industry giants.</p>
              </li>
              <li class="flex gap-4">
                <svg class="w-6 h-6 icon-accent shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <p class="text-gray-700 font-medium text-lg leading-relaxed"><strong class="text-gray-900 border-b-2" style="border-color: var(--color-page-primary)">Top Recruiters:</strong> Our students are preferred hires for Infosys, TCS, Wipro, and Adani Cement.</p>
              </li>
              <li class="flex gap-4">
                <svg class="w-6 h-6 icon-accent shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <p class="text-gray-700 font-medium text-lg leading-relaxed"><strong class="text-gray-900 border-b-2" style="border-color: var(--color-page-primary)">Growing Alumni Network:</strong> Graduates building careers across industries and continuing higher studies globally.</p>
              </li>
            </ul>
          </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="section-heading font-serif text-4xl lg:text-5xl font-bold mb-6">Tech, Talent, and <br>"Pravah"</h2>
            <div class="w-16 h-1 bg-[var(--color-page-primary)] rounded-full mb-8"></div>
            <p class="text-lg text-gray-600 font-medium mb-10 leading-relaxed">
              While our students lead the charge at the massive <strong>Karma 2026</strong> festival, COEW hosts its own signature celebrations showcasing our specific identity:
            </p>
            
            <div class="space-y-6">
              <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-all group">
                <h4 class="font-serif text-2xl font-bold icon-accent mb-3 flex items-center gap-3">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
                  Pravah
                </h4>
                <p class="text-gray-600 font-medium">Our flagship technical fest held every February. Where code meets creativity and innovation takes stage.</p>
              </div>
              <div class="bg-primary-light/20 rounded-2xl p-8 border border-[var(--color-page-secondary)] hover:shadow-lg transition-all group">
                <h4 class="font-serif text-2xl font-bold icon-accent mb-3 flex items-center gap-3">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
                  Spark
                </h4>
                <p class="text-gray-600 font-medium">The annual cultural extravaganza in March that showcases the massive artistic power of our students.</p>
              </div>
            </div>
          </div>
          <div class="relative h-[600px] rounded-3xl overflow-hidden shadow-2xl p-2 bg-gray-50">
             <img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?auto=format&fit=crop&q=80&w=1000&h=800" alt="Cultural Fest" class="w-full h-full object-cover rounded-[1.2rem]">
             <div class="absolute inset-2 bg-gradient-to-t from-[var(--color-page-primary)]/80 via-[var(--color-page-primary)]/20 to-transparent mix-blend-multiply rounded-[1.2rem]"></div>
             <div class="absolute inset-x-0 bottom-12 text-center z-10">
               <span class="inline-block px-4 py-1 border border-white/40 rounded-full text-white/90 text-xs font-bold tracking-widest uppercase mb-4 backdrop-blur-md bg-white/10">Cultural Fest</span>
