---
// src/components/Footer.astro
// Shared footer used on all pages.
---

<footer class="w-full bg-[#0a2542] text-white pt-20 relative">
  <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div>
        <div class="font-serif text-3xl font-bold mb-2">KMCT.</div>
        <div class="text-sm text-teal-400 font-bold uppercase tracking-widest mb-6">Kallanthode &amp; Pooladikunnu</div>
        <p class="text-white/60 text-sm leading-relaxed max-w-xs">9 AICTE-approved colleges in Kozhikode — built to take you from your Plus Two result to the career you planned for.</p>
      </div>

      <div>
        <h4 class="font-bold text-lg mb-6">Kallanthode Campus</h4>
        <address class="not-italic text-sm text-white/70 space-y-2 mb-6">
          <p>[Full address - confirm with KMCT]</p>
          <p>Kozhikode, Kerala - [PIN]</p>
        </address>
        <a href="mailto:mail@kmct.edu.in" class="block text-sm text-white hover:text-teal-400 transition-colors">mail@kmct.edu.in</a>
      </div>

      <div>
        <h4 class="font-bold text-lg mb-6">Pooladikunnu Campus</h4>
        <address class="not-italic text-sm text-white/70 space-y-2 mb-6">
          <p>Carino INC., Pooladikunnu Jn.</p>
          <p>Eranhikkal P.O., Elathur, Kozhikode</p>
          <p>673 303</p>
        </address>
        <p class="text-sm text-teal-400 font-bold">Nursing College Direct</p>
        <a href="mailto:collegeofnursing2001@gmail.com" class="block text-sm text-white hover:text-teal-400 transition-colors">collegeofnursing2001@gmail.com</a>
      </div>

      <div>
        <h4 class="font-bold text-lg mb-6">Quick Links</h4>
        <ul class="space-y-3 text-sm text-white/70">
          <li><a href="/"          class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/about"      class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="/admissions" class="hover:text-teal-400 text-teal-400 font-bold transition-colors">Admissions 2026–27</a></li>
          <li><a href="/#engineering"      class="hover:text-white transition-colors">Engineering - B.Tech</a></li>
          <li><a href="/#nursing"          class="hover:text-white transition-colors">Nursing - NHCON</a></li>
          <li><a href="/#pharmacy"         class="hover:text-white transition-colors">Pharmacy</a></li>
          <li><a href="/#architecture"     class="hover:text-white transition-colors">Architecture</a></li>
          <li><a href="/#business"         class="hover:text-white transition-colors">School of Business</a></li>
          <li><a href="/#teacher-education" class="hover:text-white transition-colors">Teacher Education - B.Ed</a></li>
          <li><a href="/#tti"              class="hover:text-white transition-colors">D.Ed - TTI</a></li>
          <li><a href="/#polytechnic"      class="hover:text-white transition-colors">Polytechnic</a></li>
          <li><a href="/#admissions"       class="hover:text-teal-400 text-teal-400 font-bold transition-colors mt-2 block">Admissions</a></li>
        </ul>
      </div>

    </div>

    <div class="border-t border-white/10 py-8 flex flex-col md:flex-row items-center justify-between text-white/50 text-xs">
      <p>&copy; 2026 Kunhitharuvai Memorial Charitable Trust. All rights reserved.</p>
      <div class="flex items-center gap-6 mt-4 md:mt-0">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>

  </div>
</footer>
