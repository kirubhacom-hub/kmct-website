---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT Teacher Training Institute</title>
    <meta name="description" content="Your dream of becoming a great teacher starts right here. Two years of hands-on D.El.Ed teacher training." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">
    
    <Header />

    <!-- HERO SECTION -->
    <section class="relative pt-32 pb-24 overflow-hidden bg-white flex flex-col items-center justify-center text-center px-6 isolate min-h-[85vh]">
      <!-- Background Image with 20% opacity -->
      <div class="absolute inset-0 z-0 bg-white overflow-hidden pointer-events-none">
        <div class="absolute inset-0 z-10 bg-cover bg-center" style="opacity: 0.2; background-image: url('https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=1920&h=1080');"></div>
      </div>
      
      <div class="max-w-7xl mx-auto relative z-10 text-center flex flex-col items-center mt-auto mb-auto animate-fade-up">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-pink-50/90 text-[#D81B60] border border-[#D81B60]/20 font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          NCTE Recognized &middot; SCERT Kerala Curriculum
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-4 max-w-5xl drop-shadow-sm">
          KMCT Teacher <span class="text-[#D81B60]">Training Institute</span>
        </h1>
        
        <p class="text-xl sm:text-2xl font-serif text-[#D81B60] italic mb-8 drop-shadow-sm">Your Dream of Becoming a Great Teacher Starts Here</p>
        
        <p class="text-lg sm:text-xl text-gray-600 max-w-4xl leading-relaxed font-medium mb-12">
          Join one of Kerala's most established D.El.Ed colleges in Kozhikode. Two years of hands-on teacher training that actually prepares you for the classroom. Est. 2004, and part of the KMCT Group.
        </p>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-8 justify-center mb-10 text-kmct-navy font-bold">
           <div class="flex items-center gap-2 bg-white/60 px-4 py-2 rounded-lg shadow-sm border border-gray-100 backdrop-blur-md">
             <span class="text-2xl text-[#D81B60]">20+</span> <span>Years Running</span>
           </div>
           <div class="flex items-center gap-2 bg-white/60 px-4 py-2 rounded-lg shadow-sm border border-gray-100 backdrop-blur-md">
             <span class="text-2xl text-[#D81B60]">1000+</span> <span>Teachers Trained</span>
           </div>
           <div class="flex items-center gap-2 bg-white/60 px-4 py-2 rounded-lg shadow-sm border border-gray-100 backdrop-blur-md">
             <span class="text-2xl text-[#D81B60]">50</span> <span>Seats / Year</span>
           </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#D81B60] text-white rounded-full font-bold text-sm lg:text-base hover:bg-[#ad164d] transition-all duration-300 shadow-[0_0_20px_rgba(216,27,96,0.3)] hover:-translate-y-1">
            APPLY FOR 2026-28 BATCH
          </a>
          <a href="https://wa.me/919745299888" target="_blank" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-[#0a2542] border-2 border-[#0a2542]/10 rounded-full font-bold text-sm lg:text-base hover:border-[#0a2542]/30 hover:bg-gray-50 transition-all duration-300">
            WHATSAPP TO APPLY
          </a>
        </div>
      </div>

      <!-- Infinite auto-scroll image marquee -->
      <div class="relative z-10 overflow-hidden w-full mt-16 max-w-[100vw] mx-auto pb-6" style="mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);">
        <div class="marquee-track flex gap-4 w-max">
          <!-- Set 1 -->
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&q=80&w=600&h=400" alt="Students in class" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1544928147-79a2dbc1f389?auto=format&fit=crop&q=80&w=600&h=400" alt="Teacher reading" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1531545514251-b159e38c31ce?auto=format&fit=crop&q=80&w=600&h=400" alt="Teaching" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1580894732444-8ecbef79bd1d?auto=format&fit=crop&q=80&w=600&h=400" alt="School" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=600&h=400" alt="Education" class="w-full h-full object-cover" />
          </div>
          <!-- Set 2 -->
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&q=80&w=600&h=400" alt="Students in class" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1544928147-79a2dbc1f389?auto=format&fit=crop&q=80&w=600&h=400" alt="Teacher reading" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1531545514251-b159e38c31ce?auto=format&fit=crop&q=80&w=600&h=400" alt="Teaching" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1580894732444-8ecbef79bd1d?auto=format&fit=crop&q=80&w=600&h=400" alt="School" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[240px] md:w-[280px] h-[160px] md:h-[180px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-black/5">
            <img src="https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=600&h=400" alt="Education" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT MAKES US DIFFERENT -->
    <section class="py-24 relative bg-white border-y border-gray-100">
      <div class="absolute -right-32 top-0 w-[500px] h-[500px] bg-pink-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <h2 class="font-serif text-4xl lg:text-5xl font-bold text-kmct-navy mb-6 max-w-2xl">What makes KMCT TTI different from the rest?</h2>
        <div class="w-16 h-1 bg-[#D81B60] rounded-full mb-16"></div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
          <div class="bg-gray-50/50 p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
            <div class="w-12 h-12 bg-pink-100 text-[#D81B60] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg></div>
            <h4 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Real Classroom Practice</h4>
            <p class="text-gray-600 font-medium">You don't just study theory. Extensive school internships, practice teaching, and micro-teaching means you walk into your first job ready.</p>
          </div>

          <div class="bg-gray-50/50 p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
             <div class="w-12 h-12 bg-pink-100 text-[#D81B60] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg></div>
            <h4 class="font-serif text-2xl font-bold text-kmct-navy mb-3">20+ Years of Trust</h4>
            <p class="text-gray-600 font-medium">Established in 2004 with NCTE recognition. One of the longest-running teacher training institutes in Kozhikode district.</p>
          </div>

          <div class="bg-gray-50/50 p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
             <div class="w-12 h-12 bg-pink-100 text-[#D81B60] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg></div>
            <h4 class="font-serif text-2xl font-bold text-kmct-navy mb-3">TET Ready Curriculum</h4>
            <p class="text-gray-600 font-medium">Follows SCERT Kerala's guidelines. Prepares you directly for K-TET (Kerala Teacher Eligibility Test) to land aided school jobs.</p>
          </div>

          <div class="bg-gray-50/50 p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
             <div class="w-12 h-12 bg-pink-100 text-[#D81B60] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg></div>
            <h4 class="font-serif text-2xl font-bold text-kmct-navy mb-3">Experienced Faculty</h4>
            <p class="text-gray-600 font-medium">Learn from teacher educators with 4 to 22 years of experience. They've been where you're going.</p>
          </div>

          <div class="bg-gray-50/50 p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
             <div class="w-12 h-12 bg-pink-100 text-[#D81B60] rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div>
            <h4 class="font-serif text-2xl font-bold text-kmct-navy mb-3">KMCT Group Backing</h4>
            <p class="text-gray-600 font-medium">Part of one of Kozhikode's largest educational trusts. Serious infrastructure and serious commitment.</p>
          </div>

          <div class="bg-kmct-navy text-white p-8 rounded-3xl border border-white/10 shadow-xl relative overflow-hidden group">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-[#D81B60] opacity-30 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-500"></div>
            <div class="relative z-10 w-12 h-12 bg-white/10 text-pink-300 rounded-xl flex items-center justify-center mb-6"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
            <h4 class="font-serif text-2xl font-bold mb-3 relative z-10">Affordable Fees</h4>
            <p class="text-white/80 font-medium relative z-10">Quality teacher training doesn't have to break the bank. ₹30,000 per year (merit) or ₹35,000 (management).</p>
          </div>
        </div>

        <!-- D.El.Ed Details Grid -->
        <div class="grid lg:grid-cols-2 gap-12 items-start mt-24">
          <!-- Course Details -->
          <div class="bg-gray-50 p-10 rounded-[2rem] border border-gray-100 h-full">
             <h3 class="font-serif text-3xl font-bold text-kmct-navy mb-8 border-b border-gray-200 pb-4">D.El.Ed Details</h3>
             <p class="text-gray-600 mb-6 font-medium">The D.El.Ed course is a 2-year, 4-semester programme designed by SCERT Kerala combining classroom learning with real school experience.</p>
             <ul class="space-y-4 text-gray-700 font-medium">
               <li class="flex gap-3"><span class="text-[#D81B60] mt-1">✓</span><span>Child development psychology.</span></li>
               <li class="flex gap-3"><span class="text-[#D81B60] mt-1">✓</span><span>Subject-specific teaching methods (Maths, Science, English, etc).</span></li>
               <li class="flex gap-3"><span class="text-[#D81B60] mt-1">✓</span><span>Practice teaching in real primary/upper-primary schools.</span></li>
               <li class="flex gap-3"><span class="text-[#D81B60] mt-1">✓</span><span>Community living, nature education camps.</span></li>
               <li class="flex gap-3"><span class="text-[#D81B60] mt-1">✓</span><span>Prepares you for future K-TET and B.Ed studies.</span></li>
             </ul>
          </div>
          
          <!-- Eligibility Checks -->
          <div class="bg-gray-50 p-10 rounded-[2rem] border border-gray-100 h-full">
            <h3 class="font-serif text-3xl font-bold text-kmct-navy mb-8 border-b border-gray-200 pb-4">Am I Eligible?</h3>
             <ul class="space-y-6 text-gray-700 font-medium">
               <li class="flex items-start gap-4">
                 <div class="mt-1 bg-white p-2 rounded-xl text-[#D81B60] shadow-sm"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg></div>
                 <div>
                   <h5 class="font-bold text-kmct-navy text-lg">Plus Two Passed</h5>
                   <p class="text-sm text-gray-500">From Kerala Higher Secondary Board or equivalent.</p>
                 </div>
               </li>
               <li class="flex items-start gap-4">
                 <div class="mt-1 bg-white p-2 rounded-xl text-[#D81B60] shadow-sm"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div>
                 <div>
                   <h5 class="font-bold text-kmct-navy text-lg">Minimum 50% Marks</h5>
                   <p class="text-sm text-gray-500">In Plus Two. (45% for SC/ST candidates).</p>
                 </div>
               </li>
               <li class="flex items-start gap-4">
                 <div class="mt-1 bg-white p-2 rounded-xl text-[#D81B60] shadow-sm"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg></div>
                 <div>
                   <h5 class="font-bold text-kmct-navy text-lg">Age & Residence</h5>
                   <p class="text-sm text-gray-500">Minimum 17 yrs, upper 33 yrs. Permanent resident of Kerala.</p>
                 </div>
               </li>
               <li class="flex items-start gap-4">
                 <div class="mt-1 bg-white p-2 rounded-xl text-[#D81B60] shadow-sm"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg></div>
                 <div>
                   <h5 class="font-bold text-kmct-navy text-lg">No Entrance Exam</h5>
                   <p class="text-sm text-gray-500">Admission is purely merit-based on your Plus Two marks.</p>
                 </div>
               </li>
             </ul>
          </div>
        </div>

      </div>
    </section>

    <!-- FACULTY TABLE -->
    <section class="py-24 bg-kmct-navy relative overflow-hidden text-white">
      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <h2 class="font-serif text-4xl lg:text-5xl font-bold mb-6 text-center">Our Faculty</h2>
        <p class="text-lg text-white/70 font-medium max-w-2xl mx-auto text-center mb-12">
          Learn from teachers who've dedicated their careers to training teachers. Our team of experienced educators bring decades of combined expertise.
        </p>

        <div class="bg-white/5 rounded-3xl border border-white/10 overflow-hidden backdrop-blur-md">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-white/10 text-white font-bold tracking-widest uppercase text-xs">
                  <th class="p-6">Name</th>
                  <th class="p-6">Role</th>
                  <th class="p-6">Department</th>
                  <th class="p-6">Qualification / Exp.</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/10 font-medium">
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="p-6">Rajan C</td>
                  <td class="p-6 text-pink-300">Principal</td>
                  <td class="p-6 text-white/70">-</td>
                  <td class="p-6 text-white/70">MA, MSc, MEd</td>
                </tr>
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="p-6">Roopesh V</td>
                  <td class="p-6 text-pink-200">Teacher Educator</td>
                  <td class="p-6 text-white/70">Malayalam</td>
                  <td class="p-6 text-white/70">MA, MEd <span class="bg-white/10 px-2 py-0.5 rounded text-xs ml-2">12 yrs</span></td>
                </tr>
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="p-6">Kumaran CK</td>
                  <td class="p-6 text-pink-200">Teacher Educator</td>
                  <td class="p-6 text-white/70">Art & Work</td>
                  <td class="p-6 text-white/70">KGTE <span class="bg-white/10 px-2 py-0.5 rounded text-xs ml-2">22 yrs</span></td>
                </tr>
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="p-6">Javanabai C</td>
                  <td class="p-6 text-pink-200">Teacher Educator</td>
                  <td class="p-6 text-white/70">Health & PE</td>
                  <td class="p-6 text-white/70">CPEd <span class="bg-white/10 px-2 py-0.5 rounded text-xs ml-2">20 yrs</span></td>
                </tr>
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="p-6">Jinsha I</td>
