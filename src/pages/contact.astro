---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us | KMCT Group of Institutions | All Campus Locations, Kozhikode, Kerala</title>
  <meta name="description" content="Contact KMCT Group of Institutions campus addresses, phone numbers, email, and Google Maps for Kallanthode, Manassery, Pooladikunnu, Kuttippuram, and all campuses." />
  <meta name="keywords" content="KMCT contact number, KMCT Group address, KMCT campus location, KMCT Kozhikode contact, KMCT admissions phone" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-kmct-light font-sans text-kmct-navy overflow-x-hidden">

  <Header activePage="contact" />

  <!-- HERO SECTION & QUICK ACTIONS -->
  <section class="relative overflow-hidden bg-white pt-32 pb-24 md:pt-40 md:pb-32">
    <!-- Decorative faint background -->
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&q=80&w=1920&h=1080')] bg-cover bg-center opacity-5 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-white via-white/95 to-white pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-teal-50 text-teal-800 border border-teal-200 font-bold text-xs tracking-widest uppercase shadow-sm mb-6">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        27+ INSTITUTIONS &middot; 7 CAMPUSES &middot; 3 DISTRICTS
      </div>

      <h1 class="font-serif text-5xl md:text-7xl font-bold leading-tight tracking-tight text-kmct-navy mb-6 reveal-on-scroll">
        Reach us. <br/>
        <span class="text-teal-600 italic font-serif">Any campus, any question.</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto font-medium mb-16 reveal-on-scroll" style="transition-delay: 150ms;">
        KMCT Group runs 27+ colleges across Kozhikode, Malappuram, and Kasaragod. Find every address, phone number, and map pin below.
      </p>

      <!-- Quick Action Cards (Floating Strip) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-6xl mx-auto reveal-on-scroll" style="transition-delay: 300ms;">
        
        <a href="https://wa.me/919745299888" target="_blank" class="bg-white border py-6 px-6 rounded-2xl shadow-lg border-gray-100 flex flex-col items-center justify-center gap-3 hover:-translate-y-2 hover:shadow-xl hover:border-teal-100 transition-all group">
          <div class="w-12 h-12 bg-green-50 text-green-600 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
             <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </div>
          <h3 class="font-bold text-gray-400 text-xs tracking-widest uppercase">WhatsApp Admissions</h3>
          <p class="font-bold text-kmct-navy text-xl">+91 9745299888</p>
        </a>

        <a href="tel:04952992423" class="bg-white border py-6 px-6 rounded-2xl shadow-lg border-gray-100 flex flex-col items-center justify-center gap-3 hover:-translate-y-2 hover:shadow-xl hover:border-teal-100 transition-all group">
          <div class="w-12 h-12 bg-kmct-navy/5 text-kmct-navy rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.076-6.975l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          </div>
          <h3 class="font-bold text-gray-400 text-xs tracking-widest uppercase">Call Main Office</h3>
          <p class="font-bold text-kmct-navy text-xl">0495-2992423</p>
        </a>

        <a href="mailto:mail@kmct.edu.in" class="bg-white border py-6 px-6 rounded-2xl shadow-lg border-gray-100 flex flex-col items-center justify-center gap-3 hover:-translate-y-2 hover:shadow-xl hover:border-teal-100 transition-all group">
          <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </div>
          <h3 class="font-bold text-gray-400 text-xs tracking-widest uppercase">Email Us</h3>
          <p class="font-bold text-kmct-navy text-xl">mail@kmct.edu.in</p>
        </a>

        <a href="#locations" class="bg-kmct-navy border py-6 px-6 rounded-2xl shadow-lg border-white/10 flex flex-col items-center justify-center gap-3 hover:-translate-y-2 hover:shadow-xl transition-all group cursor-pointer text-white">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          </div>
          <h3 class="font-bold text-teal-400/80 text-xs tracking-widest uppercase">Find a Campus</h3>
          <p class="font-bold text-white text-base mt-1">Scroll to See Maps</p>
        </a>

      </div>
    </div>
  </section>

  <!-- CAMPUS LOCATIONS -->
  <section id="locations" class="py-24 bg-kmct-light relative">
