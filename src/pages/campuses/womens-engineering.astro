---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>KMCT College of Engineering for Women (COEW)</title>
    <meta name="description" content="Kerala's Premier Women-Only Engineering Campus specializing in Biomedical Engineering and CSE." />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-kmct-light font-sans text-gray-800 overflow-x-hidden">
    <Header />
    
    <style is:global>
      /* Define the unique colors for the Women's Engineering college */
      :root {
        --color-page-primary: #C2185B;   /* Deep Magenta from COEW Logo */
        --color-page-secondary: #F8BBD0; /* Soft Pink Accent */
      }

      /* 2. BUTTONS & CTA */
      .btn-primary, .cta-button {
        background-color: white !important;
        color: var(--color-page-primary) !important; 
        border: 2px solid var(--color-page-primary) !important;
        transition: all 0.3s ease;
      }
      .btn-primary:hover, .cta-button:hover {
        background-color: var(--color-page-secondary) !important; 
        color: #880E4F !important; /* Darker magenta for hover text */
        border-color: #880E4F !important;
      }

      /* 3. SUBHEADINGS & ACCENTS */
      h2.section-heading, h3.section-subheading {
        color: var(--color-page-primary) !important;
      }

      .icon-accent {
        color: var(--color-page-primary) !important;
      }

      /* 4. PROGRAM CARDS */
      .program-card {
        border-top: 4px solid var(--color-page-primary) !important;
        transition: all 0.3s ease;
      }
      
      .program-card:hover {
        border-color: #880E4F !important;
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(194, 24, 91, 0.15);
      }
      
      /* Subtle primary text color */
      .text-primary {
        color: var(--color-page-primary) !important;
      }
      
      .bg-primary-light {
        background-color: var(--color-page-secondary) !important;
      }
    </style>

    <!-- HERO SECTION -->
    <section class="relative overflow-hidden" style="padding-top: 120px; background-image: linear-gradient(rgba(255,255,255,0.85), rgba(255,255,255,0.85)), url('https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-position: center top; background-color: white;">
      
      <!-- Centered hero content -->
      <div class="relative z-10 flex flex-col items-center text-center px-6 pt-20 flex-1 lg:pb-16 max-w-5xl mx-auto animate-fade-up">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-primary-light/30 text-primary border border-[var(--color-page-secondary)] font-bold text-xs tracking-widest uppercase shadow-sm mb-6 backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          Kerala's Premier Women-Only Engineering Campus
        </div>

        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] text-[#0a2542] tracking-tight mb-6 max-w-5xl drop-shadow-sm">
          Creating the Next Gen <br/>
          <span class="italic text-primary">Female Tech Leaders.</span>
        </h1>
        
        <p class="text-2xl sm:text-3xl font-serif italic text-primary mb-8 tracking-wide drop-shadow-sm">
          Designed for Women. Built for the World.
        </p>
        
        <p class="text-lg sm:text-xl text-gray-600 max-w-4xl leading-relaxed font-medium mb-12 drop-shadow-sm">
          Under the leadership of Dr. K Moidu and Dr. KM Mehboob, and the academic guidance of Dr. Sabiq P V, COEW has emerged as a premier destination for students who want to lead in specialized fields like Biomedical Engineering and CSE.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#admissions" class="inline-flex items-center justify-center gap-3 px-8 py-5 text-white rounded-full font-bold text-sm lg:text-base shadow-[0_0_20px_rgba(194,24,91,0.4)] hover:-translate-y-1 transition-all duration-300" style="background-color: var(--color-page-primary);">
            SECURE YOUR SEAT IN THE 2026 BATCH
          </a>
          <a href="https://wa.me/919745299888" target="_blank" class="inline-flex items-center justify-center gap-3 px-8 py-5 border-2 rounded-full font-bold text-sm lg:text-base hover:bg-gray-50 transition-all duration-300" style="color: var(--color-page-primary); border-color: var(--color-page-primary);">
            TALK TO A COUNSELOR
          </a>
        </div>
      </div>

      <!-- Infinite auto-scroll image marquee -->
      <div class="relative z-10 overflow-hidden pb-0" style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);">
        <div class="marquee-track flex gap-4 w-max">
          <!-- Set 1 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&q=80&w=600&h=400" alt="Students" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1581092795360-fd1ca04f0952?auto=format&fit=crop&q=80&w=600&h=400" alt="Lab" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=600&h=400" alt="Campus" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=600&h=400" alt="Mentoring" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1581093458791-9f3c3900df4b?auto=format&fit=crop&q=80&w=600&h=400" alt="Biomedical" class="w-full h-full object-cover" />
          </div>
          <!-- Set 2 -->
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&q=80&w=600&h=400" alt="Students" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1581092795360-fd1ca04f0952?auto=format&fit=crop&q=80&w=600&h=400" alt="Lab" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=600&h=400" alt="Campus" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=600&h=400" alt="Mentoring" class="w-full h-full object-cover" />
          </div>
          <div class="shrink-0 w-[280px] h-[200px] rounded-[1.5rem] overflow-hidden shadow-xl ring-1 ring-[var(--color-page-primary)]/10">
            <img src="https://images.unsplash.com/photo-1581093458791-9f3c3900df4b?auto=format&fit=crop&q=80&w=600&h=400" alt="Biomedical" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- STATS SECTION -->
    <section class="w-full bg-kmct-navy py-16 relative z-10 overflow-hidden shadow-2xl" id="campus-stats">
      <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-[#C2185B] via-pink-400 to-[#C2185B]"></div>
      <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #ffffff 0%, transparent 70%);"></div>
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-20">
        <div class="flex items-center justify-center gap-4 sm:gap-8 mb-12">
          <div class="h-[1px] bg-gradient-to-r from-transparent to-pink-500 w-16 sm:w-32 opacity-50"></div>
          <p class="text-center text-xs sm:text-sm font-bold uppercase tracking-[0.3em] text-pink-300 m-0">KMCT College of Engineering for Women — By The Numbers</p>
          <div class="h-[1px] bg-gradient-to-l from-transparent to-pink-500 w-16 sm:w-32 opacity-50"></div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-4 lg:gap-x-0 items-center lg:divide-x lg:divide-white/10">
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 0ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="62" data-suffix="%">62%</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Placement<br/>Rate</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 150ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="4" data-suffix="">4</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">B.Tech<br/>Programs</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 300ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="2" data-suffix="x">2x</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Best NSS<br/>Award Kerala</span>
          </div>
          <div class="flex flex-col items-center text-center stat-item px-4" style="transition-delay: 450ms;">
            <div class="relative mb-4 flex items-baseline justify-center">
              <span class="font-serif text-6xl lg:text-7xl font-bold text-white tabular-nums drop-shadow-lg" data-count="100" data-suffix="%">100%</span>
            </div>
            <span class="text-xs lg:text-sm font-bold text-white/60 uppercase tracking-[0.25em] leading-relaxed">Women-Only<br/>Campus</span>
          </div>
        </div>
      </div>
    </section>

    <!-- HIGHLIGHTS -->
    <section class="py-24 bg-white relative z-20 overflow-hidden">
      <!-- Decorative background blur -->
      <div class="absolute -left-64 top-0 w-[500px] h-[500px] bg-primary-light rounded-full blur-3xl opacity-30 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        
        <!-- NSS Highlights with Image -->
        <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
          <div class="flex flex-col bg-primary-light/20 rounded-3xl p-10 border border-[var(--color-page-secondary)] shadow-sm hover:shadow-md transition-shadow h-full justify-center">
            <div class="w-20 h-20 bg-white rounded-2xl flex items-center justify-center shadow-md shrink-0 border border-gray-100 mb-8">
              <svg class="w-10 h-10 icon-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
            </div>
            <h3 class="section-heading font-serif text-4xl font-bold mb-6">Best NSS unit in Kerala two years running</h3>
            <p class="text-gray-600 text-lg leading-relaxed font-medium">Our award-winning NSS unit earned top honors for two consecutive years, proving our commitment to social impact and community leadership.</p>
          </div>
          <div class="relative h-full min-h-[400px] rounded-3xl overflow-hidden shadow-xl border border-gray-100">
             <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=1000&h=800" alt="Students Collaboration" class="w-full h-full object-cover">
             <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-page-primary)]/40 to-transparent mix-blend-multiply"></div>
          </div>
        </div>

      </div>
    </section>

    <!-- PROGRAMS TABLE OVERLAY -->
    <section class="py-24 relative overflow-hidden" id="programs" style="background-image: linear-gradient(rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.95)), url('https://images.unsplash.com/photo-1581093458791-9f3c3900df4b?auto=format&fit=crop&q=80&w=1920&h=1080'); background-size: cover; background-attachment: fixed; background-position: center;">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24 relative z-10">
        <div class="text-center mb-16">
          <h2 class="section-heading font-serif text-4xl lg:text-5xl font-bold mb-6">Our B.Tech Programs</h2>
          <div class="w-24 h-1 bg-[var(--color-page-primary)] mx-auto rounded-full mb-8"></div>
          <p class="text-lg text-gray-600 font-medium max-w-2xl mx-auto">
            Choose from four specialized engineering tracks with transparent fees and high-demand industry focus.
          </p>
        </div>

        <!-- Programs Table -->
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden hover:shadow-2xl transition-shadow duration-500">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[700px]">
              <thead>
                <tr class="text-white text-sm font-bold tracking-widest uppercase" style="background-color: var(--color-page-primary);">
                  <th class="p-6 font-sans">Course Specialization</th>
                  <th class="p-6 font-sans w-32">Duration</th>
                  <th class="p-6 font-sans">Eligibility Requirement</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 font-medium text-gray-800">
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="p-6 font-bold text-lg text-primary">B.Tech Biomedical Engineering</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="p-6 font-bold text-lg text-primary">B.Tech Computer Science (CSE)</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="p-6 font-bold text-lg text-primary">B.Tech Civil Engineering</td>
                  <td class="p-6 text-gray-600 text-sm">4 Years</td>
                  <td class="p-6 text-gray-600 text-sm">KEAM Rank + 10+2 (PCM)</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors bg-primary-light/10">
                  <td class="p-6 font-bold text-lg text-primary">B.Tech Lateral Entry (LET)</td>
                  <td class="p-6 text-gray-600 text-sm">3 Years</td>
                  <td class="p-6 text-gray-600 text-sm">Merit/KMCT Poly</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- MENTORS & FACULTY CARDS -->
    <section class="py-24 bg-gray-50 border-y border-gray-200">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start mb-16">
          <div class="lg:col-span-5 relative h-[500px] lg:h-[600px] rounded-3xl overflow-hidden shadow-xl border border-gray-100 sticky top-32">
             <img src="https://images.unsplash.com/photo-1577896851231-70ef18881754?auto=format&fit=crop&q=80&w=800&h=1000" alt="Mentorship" class="w-full h-full object-cover">
          </div>
          <div class="lg:col-span-7">
            <h2 class="section-heading font-serif text-3xl lg:text-4xl xl:text-5xl font-bold mb-6 leading-tight">Global Mentors:<br>Learn from the Architects of Tech</h2>
            <div class="w-16 h-1 bg-[var(--color-page-primary)] rounded-full mb-8"></div>
            <p class="text-lg text-gray-600 font-medium mb-10 leading-relaxed">
              Learn in an environment where mentors are approachable, supportive, and aligned with industry expectations. Real expertise. Real mentorship. Real impact.
            </p>

            <div class="grid sm:grid-cols-2 gap-6">
              <div class="program-card bg-white rounded-2xl p-6 border border-gray-100 shadow-md">
                <div class="w-10 h-10 bg-primary-light/30 rounded-lg flex items-center justify-center icon-accent font-bold text-lg mb-4">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                </div>
                <p class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-1">Biomedical</p>
                <h4 class="font-serif text-xl font-bold text-gray-800 mb-2">Dr. Sameera V</h4>
                <p class="text-gray-500 text-sm">PhD-led research in medical devices and health innovation. Tech and life sciences.</p>
              </div>

              <div class="program-card bg-white rounded-2xl p-6 border border-gray-100 shadow-md">
                <div class="w-10 h-10 bg-primary-light/30 rounded-lg flex items-center justify-center icon-accent font-bold text-lg mb-4">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
                </div>
                <p class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-1">Software</p>
                <h4 class="font-serif text-xl font-bold text-gray-800 mb-2">Minilal M</h4>
                <p class="text-gray-500 text-sm">Architecture and AI expertise shaping the next generation software breakpoints.</p>
              </div>

              <div class="program-card bg-white rounded-2xl p-6 border border-gray-100 shadow-md">
                <div class="w-10 h-10 bg-primary-light/30 rounded-lg flex items-center justify-center icon-accent font-bold text-lg mb-4">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                </div>
                <p class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-1">Infrastructure</p>
                <h4 class="font-serif text-xl font-bold text-gray-800 mb-2">Aparna S</h4>
                <p class="text-gray-500 text-sm">Leads civil engineering with sustainable infrastructure and global design principles.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- SAFE CAMPUS -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 sm:px-12 lg:px-24">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="section-heading font-serif text-4xl lg:text-5xl font-bold mb-6 leading-tight">A Safe Campus.<br>A Strong Future.</h2>
            <div class="w-16 h-1 bg-[var(--color-page-primary)] rounded-full mb-8"></div>
            <p class="text-lg text-gray-600 font-medium mb-10 leading-relaxed">
              A 25km scenic drive from Kozhikode brings you to a campus that is as smart as its students.
            </p>
            
            <ul class="space-y-6">
              <li class="flex gap-4 p-4 rounded-xl hover:bg-gray-50 border border-transparent hover:border-gray-100 transition-all">
                <div class="w-12 h-12 rounded-full bg-primary-light/50 flex items-center justify-center shrink-0 mt-1 shadow-sm">
                  <svg class="w-6 h-6 icon-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-gray-800">Specialized Healthcare Labs</h4>
                  <p class="text-gray-500 mt-2 font-medium">Industry-standard equipment for Biomedical and Electronics research.</p>
                </div>
              </li>
              <li class="flex gap-4 p-4 rounded-xl hover:bg-gray-50 border border-transparent hover:border-gray-100 transition-all">
                <div class="w-12 h-12 rounded-full bg-primary-light/50 flex items-center justify-center shrink-0 mt-1 shadow-sm">
